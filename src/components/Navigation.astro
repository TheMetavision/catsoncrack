			</a>

			<div class="nav-links">
				<a href="/" class={currentPath === '/' ? 'active' : ''}>Home</a>
				<a href="/the-alley-squad" class={currentPath === '/the-alley-squad' || currentPath.startsWith('/the-alley-squad/') ? 'active' : ''}>The Alley Squad</a>
				<a href="/merch" class={currentPath === '/merch' || currentPath.startsWith('/merch/') ? 'active' : ''}>Merch</a>
				<a href="/alleyway-gazette" class={currentPath === '/alleyway-gazette' || currentPath.startsWith('/alleyway-gazette/') ? 'active' : ''}>The Alleyway Gazette</a>
