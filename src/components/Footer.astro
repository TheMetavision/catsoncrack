---
import SectionDivider from './SectionDivider.astro';
---

<SectionDivider variant="torn" />

<footer class="footer">
	<div class="footer-grain"></div>
	<div class="container footer-inner">

		<!-- Top row: logo + tagline -->
		<div class="footer-top">
			<a href="/" class="footer-logo-link">
				<img
					src="https://assets.zyrosite.com/cdn-cgi/image/format=auto,w=375,h=192,fit=crop/YanqXRJ3EDIXPJ8q/catsoncracklandscape-YNqP10bgBquLGBKp.jpeg"
					alt="Cats On Crack"
					class="footer-logo"
				/>
			</a>
			<p class="footer-tagline">Rule the streets. Break every rule.</p>
		</div>

		<!-- YouTube CTA — primary platform -->
		<div class="yt-cta-row">
			<a
				href="https://www.youtube.com/@CatsOnCrackMedia"
				target="_blank"
				rel="noopener noreferrer"
				class="yt-cta-btn"
				aria-label="Subscribe on YouTube"
			>
				<svg class="yt-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
					<path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
				</svg>
				<div class="yt-cta-text">
					<span class="yt-label">Watch on YouTube</span>
					<span class="yt-sub">@CatsOnCrack — new episodes dropping</span>
				</div>
				<span class="yt-arrow">&#8594;</span>
			</a>
		</div>

		<!-- Mid row: nav + socials -->
		<div class="footer-mid">
			<nav class="footer-nav">
				<a href="/">Home</a>
				<a href="/the-alley-squad">The Alley Squad</a>
				<a href="/merch">Merch</a>
				<a href="/alleyway-gazette">The Alleyway Gazette</a>
				<a href="/contact">Get In Touch</a>
			</nav>

			<div class="social-row">
				<a href="https://www.youtube.com/@CatsOnCrackMedia" target="_blank" rel="noopener noreferrer"
				   class="social-btn social-yt" aria-label="YouTube">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
						<path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
					</svg>
					<span>YouTube</span>
				</a>

				<a href="https://www.tiktok.com/@catsoncrackmedia" target="_blank" rel="noopener noreferrer"
				   class="social-btn social-tt" aria-label="TikTok">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
						<path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.22 8.22 0 004.79 1.53V6.77a4.85 4.85 0 01-1.02-.08z"/>
					</svg>
					<span>TikTok</span>
				</a>

				<a href="https://www.instagram.com/catsoncrack2025" target="_blank" rel="noopener noreferrer"
				   class="social-btn social-ig" aria-label="Instagram">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
						<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
					</svg>
					<span>Instagram</span>
				</a>

				<a href="https://x.com/Cats_on_Crack_" target="_blank" rel="noopener noreferrer"
				   class="social-btn social-x" aria-label="X (Twitter)">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
						<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
					</svg>
					<span>X</span>
				</a>

				<a href="https://www.facebook.com/catsoncrack" target="_blank" rel="noopener noreferrer"
				   class="social-btn social-fb" aria-label="Facebook">
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
						<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
					</svg>
					<span>Facebook</span>
				</a>
			</div>
		</div>

		<!-- Bottom bar -->
		<div class="footer-bottom">
			<div class="footer-crack-line"></div>
			<p class="copyright">&copy; Cats On Crack 2026. Part of <a href="https://www.themetavision.co.uk" target="_blank" rel="noopener noreferrer">The Metavision IP Universe</a>. All rights reserved.</p>
		</div>

	</div>
</footer>

<style>
	.footer {
		position: relative;
		background: var(--black);
		overflow: hidden;
	}

	.footer-grain {
		position: absolute;
		inset: 0;
		background-image:
			url("data:image/svg+xml,%3Csvg viewBox='0 0 300 300' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.05'/%3E%3C/svg%3E");
		background-size: 200px 200px;
		pointer-events: none;
		opacity: 0.7;
	}

	.footer-inner {
		position: relative;
		z-index: 1;
		padding-top: 60px;
		padding-bottom: 32px;
	}

	.footer-top {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 14px;
		margin-bottom: 44px;
		text-align: center;
	}

	.footer-logo-link { display: inline-block; }

	.footer-logo {
		max-width: 180px;
		opacity: 0.85;
		border-radius: 8px;
		transition: opacity 0.3s ease, transform 0.3s ease;
		filter: drop-shadow(0 0 12px rgba(255,0,255,0.25));
	}
	.footer-logo-link:hover .footer-logo {
		opacity: 1;
		transform: scale(1.04);
	}

	.footer-tagline {
		font-family: 'Bebas Neue', sans-serif;
		font-size: 0.78rem;
		letter-spacing: 5px;
		color: rgba(255,0,255,0.6);
		text-transform: uppercase;
	}

	.yt-cta-row {
		display: flex;
		justify-content: center;
		margin-bottom: 44px;
	}

	.yt-cta-btn {
		display: flex;
		align-items: center;
		gap: 16px;
		padding: 16px 28px;
		background: rgba(255, 0, 255, 0.08);
		border: 1px solid rgba(255, 0, 255, 0.3);
		color: #fff;
		text-decoration: none;
		text-shadow: none;
		transition: all 0.3s ease;
		max-width: 500px;
		width: 100%;
	}

	.yt-cta-btn:hover {
		background: rgba(255, 0, 255, 0.16);
		border-color: rgba(255, 0, 255, 0.6);
		box-shadow: 0 0 30px rgba(255, 0, 255, 0.15);
		color: #fff;
		text-shadow: none;
		transform: none;
	}

	.yt-icon {
		width: 32px;
		height: 32px;
		color: #ff00ff;
		flex-shrink: 0;
		filter: drop-shadow(0 0 8px rgba(255,0,255,0.4));
	}

	.yt-cta-text {
		display: flex;
		flex-direction: column;
		gap: 3px;
		flex: 1;
	}

	.yt-label {
		font-family: 'Bebas Neue', sans-serif;
		font-size: 1.1rem;
		letter-spacing: 2px;
		color: #fff;
	}

	.yt-sub {
		font-size: 0.72rem;
		color: rgba(255,255,255,0.45);
		letter-spacing: 0.5px;
	}

	.yt-arrow {
		font-size: 1.1rem;
		color: rgba(255,255,255,0.4);
		transition: transform 0.2s ease;
	}

	.yt-cta-btn:hover .yt-arrow {
		transform: translateX(4px);
		color: #fff;
	}

	.footer-mid {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 28px;
		margin-bottom: 44px;
	}

	.footer-nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 8px 28px;
	}

	.footer-nav a {
		font-family: 'Bebas Neue', sans-serif;
		font-size: 1rem;
		letter-spacing: 1.5px;
		color: rgba(255,255,255,0.45);
		text-shadow: none;
		transition: color 0.25s ease;
	}

	.footer-nav a:hover {
		color: var(--primary);
		text-shadow: 0 0 10px rgba(255,0,255,0.4);
	}

	.social-row {
		display: flex;
		gap: 10px;
		flex-wrap: wrap;
		justify-content: center;
	}

	.social-btn {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 9px 18px;
		background: rgba(255,255,255,0.04);
		border: 1px solid rgba(255,255,255,0.1);
		color: rgba(255,255,255,0.8);
		font-family: 'Bebas Neue', sans-serif;
		font-size: 0.78rem;
		letter-spacing: 2px;
		text-decoration: none;
		text-shadow: none;
		transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
	}

	.social-btn svg {
		width: 16px;
		height: 16px;
		flex-shrink: 0;
	}

	.social-btn:hover {
		transform: translateY(-2px);
	}

	.social-yt:hover {
		color: #FF0000;
		background: rgba(255, 0, 0, 0.1);
		border-color: rgba(255, 0, 0, 0.35);
		box-shadow: 0 0 16px rgba(255, 0, 0, 0.15);
	}

	.social-tt:hover {
		color: #69C9D0;
		background: rgba(105, 201, 208, 0.1);
		border-color: rgba(105, 201, 208, 0.35);
		box-shadow: 0 0 16px rgba(105, 201, 208, 0.15);
	}

	.social-ig:hover {
		color: #E1306C;
		background: rgba(225, 48, 108, 0.1);
		border-color: rgba(225, 48, 108, 0.35);
		box-shadow: 0 0 16px rgba(225, 48, 108, 0.15);
	}

	.social-x:hover {
		color: #1DA1F2;
		background: rgba(29, 161, 242, 0.1);
		border-color: rgba(29, 161, 242, 0.35);
		box-shadow: 0 0 16px rgba(29, 161, 242, 0.15);
	}

	.social-fb:hover {
		color: #1877F2;
		background: rgba(24, 119, 242, 0.1);
		border-color: rgba(24, 119, 242, 0.35);
		box-shadow: 0 0 16px rgba(24, 119, 242, 0.15);
	}

	.footer-bottom {
		text-align: center;
	}

	.footer-crack-line {
		width: 100%;
		height: 1px;
		background: linear-gradient(90deg,
			transparent 0%,
			rgba(255,0,255,0.2) 20%,
			rgba(255,0,255,0.4) 50%,
			rgba(255,0,255,0.2) 80%,
			transparent 100%
		);
		margin-bottom: 20px;
		position: relative;
	}

	.footer-crack-line::after {
		content: '';
		position: absolute;
		top: -1px;
		left: 30%;
		width: 40%;
		height: 3px;
		background: linear-gradient(90deg, transparent, rgba(255,0,255,0.15), transparent);
		filter: blur(3px);
	}

	.copyright {
		font-size: 0.75rem;
		color: rgba(255,255,255,0.2);
		letter-spacing: 1px;
	}

	.copyright a {
		color: rgba(255,255,255,0.4);
		text-decoration: underline;
		text-underline-offset: 2px;
		transition: color 0.2s ease;
	}

	.copyright a:hover {
		color: rgba(255,255,255,0.7);
	}

	@media (max-width: 640px) {
		.yt-cta-btn { padding: 14px 20px; gap: 12px; }
		.footer-nav { gap: 8px 20px; }
	}
</style>
