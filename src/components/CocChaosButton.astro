  /* ── Idle in-place chromatic jitter (Arc D.1) ───────────────────────────── */
  /* Triggered by JS: adds .coc-idle-jitter for ~50ms then removes. Pure CSS
     handles the visual treatment — text-shadow chromatic split on glyph. */

  .coc-chaos__button.coc-idle-jitter .coc-chaos__glyph--play {
    filter: drop-shadow(-2px 0 0 #00ffff) drop-shadow(2px 0 0 #ff00ff);
  }
  .coc-chaos__button.coc-idle-jitter .coc-chaos__hover-text {
    text-shadow: -2px 0 0 #00ffff, 2px 0 0 #ff00ff;
  }

  /* ── Click-impulse chromatic flash on glyph (Arc D.3, ~50ms) ────────────── */

  .coc-chaos__button.coc-click-impulse .coc-chaos__glyph--play {
    filter: drop-shadow(-3px 0 0 #00ffff) drop-shadow(3px 0 0 #ff00ff);
  }

  /* ── Reduced-motion (Section D.8) — most extensive of the four brands ───── */
  /* All animations disabled. Misshapen identity preserved STATICALLY. */

  @media (prefers-reduced-motion: reduce) {
