    .coc-state-ended .coc-chaos__button {
      transform: skewY(-2deg) translateY(2px) !important;
    }
  }

  /* ── Mobile (≤640px) — disable expensive effects per Arc F ──────────────── */
  /* JS already gates idle-jitter + logo-aberration on mobile via matchMedia.
