      filter: none !important;
    }
    .coc-chaos__button.coc-click-impulse .coc-chaos__glyph--play {
      filter: none !important;
    }
    .coc-chaos__button.coc-idle-jitter .coc-chaos__hover-text {
      text-shadow: none !important;
    }
