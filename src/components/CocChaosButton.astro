  @keyframes coc-wobble {
    0%   { transform: scale(1.0) rotate(-0.5deg); }
    50%  { transform: scale(1.05) rotate(0.5deg); }
    100% { transform: scale(1.0) rotate(-0.5deg); }
  }

  .coc-state-playing .coc-chaos__button,
  .coc-state-replaying .coc-chaos__button {
    animation: coc-wobble 700ms ease-in-out infinite alternate;
  }

