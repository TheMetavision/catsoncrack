---
import { client as sanityClient } from '../lib/sanity'
const links = await sanityClient.fetch(`*[_type == "legalPage" && showInFooter == true] | order(order asc){ title, slug }`)
---
<nav class="legal-nav" aria-label="Legal">
  <ul>
    {links.map((l: any) => (
      <li><a href={`/legal/${l.slug.current}`}>{l.title}</a></li>
    ))}
  </ul>
</nav>

<style>
  .legal-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 28px;
  }
  .legal-nav li {
    list-style: none;
  }
  .legal-nav a {
    font-family: "Bebas Neue", sans-serif;
    font-size: 0.78rem;
    letter-spacing: 1.5px;
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.25s ease, text-shadow 0.25s ease;
  }
  .legal-nav a:hover {
    color: #ff00ff;
    text-shadow: 0 0 10px rgba(255, 0, 255, 0.4);
  }
</style>
