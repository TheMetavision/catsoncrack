---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Get In Touch - Cats On Crack" description="Connect with the Cats On Crack crew. Whether you have questions, feedback, or collaboration ideas, we want to hear from you!">
	<Navigation />

	<main>
		<section class="hero-banner">
			<div class="hero-noise"></div>
			<div class="container hero-inner">
				<p class="hero-eyebrow">Say What's On Your Mind</p>
				<h1 class="page-title">Get In Touch</h1>
				<p class="hero-subtitle">Got something to say? We're all ears (and whiskers)</p>
			</div>
		</section>

		<section class="section contact-section">
			<div class="container">
				<div class="contact-top">
					<div class="contact-intro fade-in">
						<h2 class="glow-text">Let's Connect</h2>
						<p class="intro-text">Whether you're a fan, a potential collaborator, or just curious about the crew, we'd love to hear from you. Drop us a message and let's start a conversation.</p>
					</div>
					<div class="contact-feature-image fade-in">
						<img src="/images/coc-heist.jpg" alt="Cats On Crack - The Heist" />
					</div>
				</div>

				<div class="contact-bottom">
					<div class="contact-info fade-in">
						<div class="contact-methods">
							<div class="contact-method">
								<div class="method-icon">📧</div>
								<h3>Email Us</h3>
								<p>For general inquiries, fan mail, or business opportunities</p>
								<a href="mailto:info@catsoncrack.co.uk">info@catsoncrack.co.uk</a>
							</div>

							<div class="contact-method">
								<div class="method-icon">📱</div>
								<h3>Social Media</h3>
								<p>Follow us for daily updates, behind-the-scenes content, and more</p>
								<div class="social-links">
									<a href="https://www.youtube.com/@CatsOnCrackMedia" target="_blank" rel="noopener noreferrer" class="social-link social-yt" aria-label="YouTube">
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
										<span>YouTube</span>
									</a>
									<a href="https://www.tiktok.com/@catsoncrackmedia" target="_blank" rel="noopener noreferrer" class="social-link social-tt" aria-label="TikTok">
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.22 8.22 0 004.79 1.53V6.77a4.85 4.85 0 01-1.02-.08z"/></svg>
										<span>TikTok</span>
									</a>
									<a href="https://www.instagram.com/catsoncrack2025" target="_blank" rel="noopener noreferrer" class="social-link social-ig" aria-label="Instagram">
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
										<span>Instagram</span>
									</a>
									<a href="https://x.com/Cats_on_Crack_" target="_blank" rel="noopener noreferrer" class="social-link social-x" aria-label="X">
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
										<span>X</span>
									</a>
									<a href="https://www.facebook.com/catsoncrack" target="_blank" rel="noopener noreferrer" class="social-link social-fb" aria-label="Facebook">
										<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
										<span>Facebook</span>
									</a>
								</div>
							</div>

							<div class="contact-method">
								<div class="method-icon">💼</div>
								<h3>Collaborations</h3>
								<p>Interested in working together? Let's make something legendary</p>
								<a href="mailto:collabs@catsoncrack.co.uk">collabs@catsoncrack.co.uk</a>
							</div>
						</div>
					</div>

					<div class="contact-form-wrapper fade-in">
						<form class="contact-form" id="contactForm" action="https://api.web3forms.com/submit" method="POST">
							<input type="hidden" name="access_key" value="c1f6d9fd-c10e-4633-a842-19702c4e5ab2" />
							<input type="hidden" name="subject" value="New Contact Form Submission - Cats On Crack" />
							<input type="hidden" name="from_name" value="Cats On Crack Website" />
							<input type="hidden" name="redirect" value="https://catsoncrack.netlify.app/contact?success=true" />
							<input type="checkbox" name="botcheck" class="hidden-field" style="display:none" />
							<h3>Send Us a Message</h3>

							<div class="form-group">
								<label for="name">Your Name</label>
								<input type="text" id="name" name="name" required placeholder="What should we call you?" />
							</div>

							<div class="form-group">
								<label for="email">Email Address</label>
								<input type="email" id="email" name="email" required placeholder="your@email.com" />
							</div>

							<div class="form-group">
								<label for="topic">Subject</label>
								<select id="topic" name="topic" required>
									<option value="">Choose a topic...</option>
									<option value="General Inquiry">General Inquiry</option>
									<option value="Fan Message">Fan Message</option>
									<option value="Collaboration">Collaboration</option>
									<option value="Press & Media">Press & Media</option>
									<option value="Merch Question">Merch Question</option>
									<option value="Other">Other</option>
								</select>
							</div>

							<div class="form-group">
								<label for="message">Message</label>
								<textarea id="message" name="message" required placeholder="Tell us what's on your mind..." rows="6"></textarea>
							</div>

							<button type="submit" class="submit-button">Send Message</button>
						</form>
					</div>
				</div>
			</div>
		</section>

		<section class="section faq-section">
			<div class="container">
				<h2 class="section-title glow-text">Frequently Asked Questions</h2>
				<div class="faq-grid">
					<div class="faq-item fade-in">
						<h3>When will the next episode be released?</h3>
						<p>We're currently in production on Season 1. Subscribe to our newsletter to be the first to know about release dates and exclusive previews!</p>
					</div>

					<div class="faq-item fade-in">
						<h3>Where can I buy the books?</h3>
						<p>The Cats On Crack book series will be available soon on major online retailers. Sign up for our newsletter to get notified when they drop!</p>
					</div>

					<div class="faq-item fade-in">
						<h3>Is the merch store open?</h3>
						<p>The official merch store is launching soon! Check out our <a href="/merch">Merch page</a> to see what's coming and get on the early access list.</p>
					</div>

					<div class="faq-item fade-in">
						<h3>Can I use your characters in my own content?</h3>
						<p>Thanks for your interest! For any licensing or permission requests, please email us at collabs@catsoncrack.co.uk with details about your project.</p>
					</div>

					<div class="faq-item fade-in">
						<h3>Are you looking for voice actors or animators?</h3>
						<p>We love working with talented creatives! Send your portfolio and a brief introduction to collabs@catsoncrack.co.uk. We review all submissions.</p>
					</div>

					<div class="faq-item fade-in">
						<h3>How can I support the project?</h3>
						<p>Follow us on social media, share our content, subscribe to our newsletter, and spread the word! Community support means everything to us.</p>
					</div>
				</div>
			</div>
		</section>

		<section class="section cta-section">
			<div class="container">
				<div class="cta-box fade-in">
					<h2 class="glow-text">Join the Crew</h2>
					<p>Don't miss out on exclusive content, early access, and behind-the-scenes updates. Subscribe to our newsletter and become part of the alley gang!</p>
					<a href="/#newsletter" class="cta-button">Subscribe Now</a>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<style>
	.hidden-field {
		display: none;
	}

	.form-success {
		text-align: center;
		padding: 40px 20px;
	}

	.form-success h3 {
		color: var(--primary);
		font-size: 2rem;
		margin-bottom: 15px;
	}

	.form-success p {
		color: var(--text-secondary);
		font-size: 1.1rem;
		line-height: 1.7;
	}

	.hero-banner {
		background: #181b22;
		padding: 150px 0 80px;
		text-align: center;
		position: relative;
		overflow: hidden;
	}

	.hero-noise {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse at 30% 50%, rgba(255,0,255,0.1) 0%, transparent 60%),
			radial-gradient(ellipse at 70% 30%, rgba(255,0,255,0.05) 0%, transparent 50%);
		pointer-events: none;
	}

	.hero-inner {
		position: relative;
	}

	.hero-eyebrow {
		font-family: 'Bebas Neue', sans-serif;
		font-size: 0.85rem;
		letter-spacing: 5px;
		color: #ff00ff;
		text-transform: uppercase;
		margin-bottom: 12px;
		opacity: 0.9;
	}

	.page-title {
		font-family: 'Bebas Neue', sans-serif;
		font-size: clamp(4rem, 10vw, 9rem);
		margin-bottom: 20px;
		position: relative;
		color: #ffffff;
		line-height: 0.9;
		letter-spacing: 4px;
		text-shadow:
			4px 4px 0 rgba(255,0,255,0.4),
			8px 8px 0 rgba(255,0,255,0.15),
			0 0 60px rgba(255,0,255,0.2);
	}

	.hero-subtitle {
		font-family: 'Bebas Neue', sans-serif;
		font-size: 1.1rem;
		color: rgba(255,255,255,0.5);
		position: relative;
		letter-spacing: 2px;
		text-transform: uppercase;
	}

	.contact-section {
		background: var(--bg-navy);
	}

	.contact-top {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 80px;
		align-items: center;
		margin-bottom: 50px;
	}

	.contact-feature-image {
		border-radius: 12px;
		overflow: hidden;
		border: 2px solid rgba(255, 0, 255, 0.2);
		transition: all 0.3s ease;
	}

	.contact-feature-image:hover {
		border-color: var(--primary);
		box-shadow: 0 10px 30px rgba(255, 0, 255, 0.2);
	}

	.contact-feature-image img {
		width: 100%;
		display: block;
	}

	.contact-bottom {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 80px;
		align-items: stretch;
	}

	.contact-info h2 {
		font-size: clamp(2rem, 4vw, 3rem);
		color: var(--primary);
		margin-bottom: 20px;
	}

	.intro-text {
		font-size: 1.1rem;
		color: var(--text-secondary);
		line-height: 1.8;
		margin-bottom: 40px;
	}

	.contact-methods {
		display: flex;
		flex-direction: column;
		gap: 35px;
	}

	.contact-method {
		padding: 25px;
		background: var(--bg-card);
		border-radius: 12px;
		border: 2px solid rgba(255, 0, 255, 0.2);
		transition: all 0.3s ease;
	}

	.contact-method:hover {
		border-color: var(--primary);
		box-shadow: 0 10px 30px rgba(255, 0, 255, 0.2);
		transform: translateX(10px);
	}

	.method-icon {
		font-size: 3rem;
		margin-bottom: 15px;
	}

	.contact-method h3 {
		font-size: 1.5rem;
		color: var(--primary);
		margin-bottom: 10px;
	}

	.contact-method p {
		color: var(--text-secondary);
		margin-bottom: 15px;
		line-height: 1.6;
	}

	.contact-method a {
		color: var(--primary);
		font-weight: 700;
		transition: all 0.3s ease;
	}

	.contact-method a:hover {
		color: var(--primary-light);
		text-shadow: var(--glow);
	}

	.social-links {
		display: flex;
		gap: 10px;
		flex-wrap: wrap;
	}

	.social-link {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 8px 16px;
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 0, 255, 0.35);
		border-radius: 999px;
		color: rgba(255, 255, 255, 0.8);
		font-family: 'Bebas Neue', sans-serif;
		font-size: 0.8rem;
		letter-spacing: 1.5px;
		text-decoration: none;
		text-shadow: none;
		transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
	}

	.social-link:hover {
		transform: translateY(-2px);
	}

	.social-link.social-yt:hover {
		color: #FF0000;
		background: rgba(255, 0, 0, 0.1);
		border-color: rgba(255, 0, 0, 0.4);
		box-shadow: 0 0 14px rgba(255, 0, 0, 0.15);
	}

	.social-link.social-tt:hover {
		color: #69C9D0;
		background: rgba(105, 201, 208, 0.1);
		border-color: rgba(105, 201, 208, 0.4);
		box-shadow: 0 0 14px rgba(105, 201, 208, 0.15);
	}

	.social-link.social-ig:hover {
		color: #E1306C;
		background: rgba(225, 48, 108, 0.1);
		border-color: rgba(225, 48, 108, 0.4);
		box-shadow: 0 0 14px rgba(225, 48, 108, 0.15);
	}

	.social-link.social-x:hover {
		color: #1DA1F2;
		background: rgba(29, 161, 242, 0.1);
		border-color: rgba(29, 161, 242, 0.4);
		box-shadow: 0 0 14px rgba(29, 161, 242, 0.15);
	}

	.social-link.social-fb:hover {
		color: #1877F2;
		background: rgba(24, 119, 242, 0.1);
		border-color: rgba(24, 119, 242, 0.4);
		box-shadow: 0 0 14px rgba(24, 119, 242, 0.15);
	}

	.contact-form-wrapper {
		background: var(--bg-card);
		padding: 40px;
		border-radius: 12px;
		border: 2px solid rgba(255, 0, 255, 0.2);
		display: flex;
		flex-direction: column;
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		flex: 1;
	}

	.contact-form .form-group:last-of-type {
		flex: 1;
		display: flex;
		flex-direction: column;
	}

	.contact-form .form-group:last-of-type textarea {
		flex: 1;
	}

	.contact-form h3 {
		font-size: 2rem;
		color: var(--primary);
		margin-bottom: 30px;
	}

	.form-group {
		margin-bottom: 25px;
	}

	.form-group label {
		display: block;
		color: var(--text-primary);
		font-weight: 700;
		margin-bottom: 8px;
		font-size: 1rem;
	}

	.form-group input,
	.form-group select,
	.form-group textarea {
		width: 100%;
		padding: 14px 18px;
		background: var(--bg-darker);
		border: 2px solid rgba(255, 0, 255, 0.3);
		border-radius: 8px;
		color: var(--text-primary);
		font-size: 1rem;
		font-family: 'Inter', sans-serif;
		transition: all 0.3s ease;
	}

	.form-group input:focus,
	.form-group select:focus,
	.form-group textarea:focus {
		outline: none;
		border-color: var(--primary);
		box-shadow: 0 0 0 3px rgba(255, 0, 255, 0.1);
	}

	.form-group textarea {
		resize: vertical;
		min-height: 150px;
	}

	.submit-button {
		width: 100%;
		padding: 16px;
		background: var(--accent-gradient);
		color: white;
		font-size: 1.2rem;
		font-weight: 900;
		letter-spacing: 2px;
		border-radius: 8px;
		text-transform: uppercase;
		box-shadow: 0 4px 20px rgba(255, 0, 255, 0.4);
		transition: all 0.3s ease;
		text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
	}

	.submit-button:hover {
		transform: translateY(-3px);
		box-shadow: var(--glow-strong);
	}

	.faq-section {
		background: var(--bg-dark);
	}

	.section-title {
		font-size: clamp(2.5rem, 5vw, 4rem);
		color: var(--primary);
		text-align: center;
		margin-bottom: 60px;
	}

	.faq-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
		gap: 30px;
	}

	.faq-item {
		background: var(--bg-card);
		padding: 30px;
		border-radius: 12px;
		border: 2px solid rgba(255, 0, 255, 0.2);
		transition: all 0.3s ease;
	}

	.faq-item:hover {
		border-color: var(--primary);
		box-shadow: 0 10px 30px rgba(255, 0, 255, 0.2);
	}

	.faq-item h3 {
		font-size: 1.4rem;
		color: var(--primary);
		margin-bottom: 15px;
	}

	.faq-item p {
		color: var(--text-secondary);
		line-height: 1.7;
	}

	.faq-item a {
		color: var(--primary);
		font-weight: 700;
	}

	.cta-section {
		background: var(--bg-navy);
	}

	.cta-box {
		background: var(--bg-card);
		padding: 60px;
		border-radius: 20px;
		text-align: center;
		border: 3px solid var(--primary);
		box-shadow: 0 0 40px rgba(255, 0, 255, 0.3);
	}

	.cta-box h2 {
		font-size: clamp(2rem, 4vw, 3rem);
		color: var(--primary);
		margin-bottom: 20px;
	}

	.cta-box p {
		font-size: 1.2rem;
		color: var(--text-secondary);
		margin-bottom: 30px;
		line-height: 1.8;
	}

	.cta-button {
		display: inline-block;
		padding: 16px 50px;
		background: var(--accent-gradient);
		color: white;
		font-size: 1.3rem;
		font-weight: 900;
		letter-spacing: 2px;
		border-radius: 8px;
		text-transform: uppercase;
		box-shadow: 0 4px 20px rgba(255, 0, 255, 0.4);
		transition: all 0.3s ease;
		text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
	}

	.cta-button:hover {
		transform: translateY(-3px);
		box-shadow: var(--glow-strong);
		color: white;
	}

	@media (max-width: 968px) {
		.contact-top {
			grid-template-columns: 1fr;
			gap: 40px;
		}

		.contact-bottom {
			grid-template-columns: 1fr;
			gap: 40px;
