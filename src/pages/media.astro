---
// src/pages/media.astro
//
// Cats On Crack — /media page
// v2 — 2026-05-01 — added missing <Navigation /> + <Footer /> renders
//                   (Layout.astro body is just <slot /> + <CartDrawer />,
//                    so each page must render Nav + Footer itself)
//
// Three sections: hero trailer + episodes grid + book series.
// All videos play in a shared lightbox modal (single iframe, swap on open).
//
// Author: Axiom, 2026-04-30
// Brand voice: Alleyway Gazette neutral framing + Cats On Crack chaos register

import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { getAllEpisodes } from '../lib/sanity';

const HERO_TRAILER_FALLBACK_ID = 'ay215yKvntY';

const episodes = (await getAllEpisodes()) || [];

const featured = episodes.find((e) => e.featured) || episodes[0] || null;
const heroYoutubeId =
  (featured && (featured.youtubeId || extractYoutubeId(featured.youtubeUrl))) ||
  HERO_TRAILER_FALLBACK_ID;
const heroTitle = (featured && featured.title) || 'Cats On Crack Official Trailer';
const heroDescription =
  (featured && featured.description) ||
  "Meet the wildest alley cats you'll ever encounter. Six cats. Zero rules. One alley.";

function extractYoutubeId(url) {
  if (!url) return null;
  const patterns = [
    /youtu\.be\/([a-zA-Z0-9_-]{6,})/,
    /youtube\.com\/(?:watch\?v=|embed\/|shorts\/|v\/)([a-zA-Z0-9_-]{6,})/,
  ];
  for (const re of patterns) {
    const m = url.match(re);
    if (m) return m[1];
  }
  return null;
}

const episodeCards = episodes
  .filter((e) => !featured || e._id !== featured._id)
  .map((e) => ({
    ...e,
    resolvedYoutubeId: e.youtubeId || extractYoutubeId(e.youtubeUrl),
    thumbUrl: null,
  }));

const PLACEHOLDER_BOOKS = [
  {
    volume: 'Vol. 01',
    title: 'Tales from the Alleyway',
    teaser:
      "Whiskers' first big play for the alley. Pipe Heist of '25 in full, with the parts the Gazette couldn't print.",
  },
  {
    volume: 'Vol. 02',
    title: 'Crack-Pipe Capers',
    teaser:
      'Smudge writes a crew handbook. Trixie spray-paints over half of it. Gizmo invents three things, two of them dangerous.',
  },
  {
    volume: 'Vol. 03',
    title: 'Long Live the King',
    teaser:
      'A challenger from the east side. The Dumpster Throne under siege. Six cats, zero rules, one bloody-great showdown.',
  },
];

const ldEpisodes = episodeCards
  .filter((e) => e.resolvedYoutubeId)
  .map((e, idx) => ({
    '@type': 'VideoObject',
    position: idx + 1,
    name: e.title,
    description: e.description,
    thumbnailUrl: `https://img.youtube.com/vi/${e.resolvedYoutubeId}/maxresdefault.jpg`,
    embedUrl: `https://www.youtube.com/embed/${e.resolvedYoutubeId}`,
    uploadDate: e.publishedAt || undefined,
  }));

const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://catsoncrack.co.uk/media#page',
  name: 'Cats On Crack — Media',
  description:
    'The animated series, the trailer, and the book series — all the chaos in one place.',
  url: 'https://catsoncrack.co.uk/media',
  isPartOf: {
    '@type': 'WebSite',
    name: 'Cats On Crack',
    url: 'https://catsoncrack.co.uk',
  },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: ldEpisodes,
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://catsoncrack.co.uk/' },
    { '@type': 'ListItem', position: 2, name: 'Media', item: 'https://catsoncrack.co.uk/media' },
  ],
};
---

<Layout
  title="Media — Cats On Crack"
  description="Watch the animated series, catch the trailer, and explore the Cats On Crack book series. The Wildest Alley Cats You'll Ever Meet."
  jsonLd={[collectionLd, breadcrumbLd]}
>
  <Navigation />

  <main class="media-page">

    {/* ── HERO ─────────────────────────────────────────────────────────── */}
    <section class="section media-hero">
      <div class="container">
        <div class="media-hero-grid">
          <div class="media-hero-text fade-right hero-anim-immediate">
            <div class="eyebrow">Media</div>
            <h1 class="main-title glow-text">
              The Stories.<br>The Series.<br>The Mayhem.
            </h1>
            <p class="hero-body">
              Episodes, trailers, and the book series — every scrap of footage
              the Alleyway Gazette could get its paws on. Pull up a dumpster.
            </p>
            <div class="hero-cta-row">
              <a href="#episodes" class="cta-button primary-cta">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                  <path d="M8 5v14l11-7z"/>
                </svg>
                Watch the Episodes
              </a>
              <a href="#books" class="cta-button secondary-cta">
                See the Books
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
                  <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
                </svg>
              </a>
            </div>
          </div>

          <div class="media-hero-trailer fade-left hero-anim-immediate">
            <button
              type="button"
              class="trailer-card"
              data-youtube-id={heroYoutubeId}
              data-trigger="open-video-modal"
              aria-label={`Play: ${heroTitle}`}
            >
              <div class="trailer-thumb-wrap">
                <img
                  class="trailer-thumb"
                  src={`https://img.youtube.com/vi/${heroYoutubeId}/maxresdefault.jpg`}
                  alt={`${heroTitle} thumbnail`}
                  loading="eager"
                  width="640"
                  height="360"
                />
                <div class="trailer-overlay"></div>
                <div class="trailer-play-glow">
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
                <div class="trailer-badge">Trailer</div>
              </div>
              <div class="trailer-meta">
                <h3 class="trailer-title">{heroTitle}</h3>
                <p class="trailer-desc">{heroDescription}</p>
              </div>
            </button>
          </div>
        </div>
      </div>
    </section>

    {/* ── EPISODES GRID ────────────────────────────────────────────────── */}
    <section class="section media-episodes" id="episodes">
      <div class="container">
        <div class="section-heading-block fade-up">
          <div class="eyebrow">Episodes</div>
          <h2 class="section-title glow-text">From the Alleyways</h2>
          <p class="section-sub">
            Field recordings of feline mayhem. New episodes drop on
            <a
              href="https://www.youtube.com/@CatsOnCrackMedia"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-link"
            >@CatsOnCrack on YouTube</a> &mdash; subscribe so you don't miss a thing.
          </p>
        </div>

        {episodeCards.length > 0 ? (
          <div class="episodes-grid stagger-children">
            {episodeCards.map((ep) => {
              const hasVideo = !!ep.resolvedYoutubeId;
              const thumbSrc = hasVideo
                ? `https://img.youtube.com/vi/${ep.resolvedYoutubeId}/maxresdefault.jpg`
                : null;
              return (
                <article class={`episode-card ${hasVideo ? 'is-playable' : 'is-coming-soon'}`}>
                  <button
                    type="button"
                    class="episode-card-button"
                    data-youtube-id={ep.resolvedYoutubeId || ''}
                    data-trigger={hasVideo ? 'open-video-modal' : 'coming-soon'}
                    aria-label={hasVideo ? `Play: ${ep.title}` : `${ep.title} — coming soon`}
                  >
                    <div class="episode-thumb-wrap">
                      {thumbSrc ? (
                        <img
                          class="episode-thumb"
                          src={thumbSrc}
                          alt={`${ep.title} thumbnail`}
                          loading="lazy"
                          width="480"
                          height="270"
                        />
                      ) : (
                        <div class="episode-thumb-placeholder" aria-hidden="true">
                          <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="6" width="26" height="20" rx="2"/>
                            <path d="M14 12 L20 16 L14 20 Z" fill="currentColor"/>
                          </svg>
                          <span>Footage Pending</span>
                        </div>
                      )}
                      <div class="episode-overlay"></div>
                      {hasVideo ? (
                        <div class="episode-play">
                          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path d="M8 5v14l11-7z"/>
                          </svg>
                        </div>
                      ) : (
                        <div class="episode-coming-badge">Coming Soon</div>
                      )}
                    </div>
                    <div class="episode-meta">
                      <h3 class="episode-title">{ep.title}</h3>
                      <p class="episode-desc">{ep.description}</p>
                    </div>
                  </button>
                </article>
              );
            })}
          </div>
        ) : (
          <p class="empty-state">No episodes loaded. Check back soon — the Gazette is on it.</p>
        )}
      </div>
    </section>

    {/* ── BOOK SERIES (anchor: #books) ─────────────────────────────────── */}
    <section class="section media-books" id="books">
      <div class="container">
        <div class="section-heading-block fade-up">
          <div class="eyebrow">Book Series</div>
          <h2 class="section-title glow-text">Crack Open the Spine</h2>
          <p class="section-sub">
            Three volumes. The full Cats On Crack chronicle, written down where
            the cats can't deny it. <strong>Coming Soon.</strong>
          </p>
        </div>

        <div class="books-grid stagger-children">
          {PLACEHOLDER_BOOKS.map((b) => (
            <article class="book-card">
              <div class="book-cover">
                <div class="book-cover-inner">
                  <span class="book-cover-volume">{b.volume}</span>
                  <span class="book-cover-glyph" aria-hidden="true">CoC</span>
                </div>
                <div class="book-cover-coming">Coming Soon</div>
              </div>
              <div class="book-meta">
                <h3 class="book-title">{b.title}</h3>
                <p class="book-teaser">{b.teaser}</p>
                <p class="book-volume-label">{b.volume}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="books-cta-row fade-up">
          <p class="books-cta-text">
            Want the alert when Volume 01 drops? Slide into the Alleyway Gazette
            for sneaky schemes and ship dates.
          </p>
          <a href="/alleyway-gazette" class="cta-button secondary-cta">
            Visit The Gazette
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
              <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
            </svg>
          </a>
        </div>
      </div>
    </section>

    {/* ── CHANNEL CTA STRIP ─────────────────────────────────────────────── */}
    <section class="section media-channel-strip">
      <div class="container">
        <div class="channel-strip fade-up">
          <div class="channel-strip-text">
            <div class="eyebrow eyebrow-light">Subscribe</div>
            <h2 class="channel-strip-title glow-text">
              Catch every drop on YouTube
            </h2>
            <p>
              The series lives there. New episodes, behind-the-scenes scraps, the
              occasional deleted scene Smudge insisted should never see daylight.
            </p>
          </div>
          <a
            href="https://www.youtube.com/@CatsOnCrackMedia"
            target="_blank"
            rel="noopener noreferrer"
            class="cta-button primary-cta channel-strip-cta"
            aria-label="Subscribe to Cats On Crack on YouTube"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
            Subscribe on YouTube
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />

  {/* ── VIDEO LIGHTBOX MODAL ─────────────────────────────────────────── */}
  <div
    id="cocVideoModal"
    class="video-modal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="cocVideoModalTitle"
    aria-hidden="true"
  >
    <button type="button" class="video-modal-backdrop" data-close="modal" aria-label="Close video"></button>
    <div class="video-modal-panel" role="document">
      <div class="video-modal-header">
        <span id="cocVideoModalTitle" class="video-modal-title">Now Playing</span>
        <button type="button" class="video-modal-close" data-close="modal" aria-label="Close video">
          <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
            <path d="M6 6 L18 18 M18 6 L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
          </svg>
        </button>
      </div>
      <div class="video-modal-frame">
        <iframe
          id="cocVideoModalIframe"
          title="Cats On Crack video"
          allow="autoplay; encrypted-media; picture-in-picture"
          allowfullscreen
          frameborder="0"
        ></iframe>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const modal = document.getElementById('cocVideoModal');
      const iframe = document.getElementById('cocVideoModalIframe');
      const titleEl = document.getElementById('cocVideoModalTitle');
      if (!modal || !iframe || !titleEl) return;

      let lastFocusedTrigger = null;

      function openModal(youtubeId, label) {
        if (!youtubeId) return;
        const src = `https://www.youtube.com/embed/${youtubeId}?autoplay=1&rel=0&modestbranding=1`;
        iframe.setAttribute('src', src);
        if (label) titleEl.textContent = label;
        modal.classList.add('is-open');
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        const closeBtn = modal.querySelector('.video-modal-close');
        if (closeBtn) closeBtn.focus();
      }

      function closeModal() {
        iframe.setAttribute('src', '');
        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        if (lastFocusedTrigger && typeof lastFocusedTrigger.focus === 'function') {
          lastFocusedTrigger.focus();
        }
      }

      document.addEventListener('click', (e) => {
        const trigger = e.target instanceof Element ? e.target.closest('[data-trigger="open-video-modal"]') : null;
        if (trigger) {
          e.preventDefault();
          lastFocusedTrigger = trigger;
          openModal(trigger.dataset.youtubeId, trigger.getAttribute('aria-label'));
          return;
        }
        const csTrigger = e.target instanceof Element ? e.target.closest('[data-trigger="coming-soon"]') : null;
        if (csTrigger) {
          e.preventDefault();
          csTrigger.classList.add('coming-soon-shake');
          window.setTimeout(() => csTrigger.classList.remove('coming-soon-shake'), 450);
        }
      });

      modal.addEventListener('click', (e) => {
        const closer = e.target instanceof Element ? e.target.closest('[data-close="modal"]') : null;
        if (closer) closeModal();
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.classList.contains('is-open')) {
          closeModal();
        }
      });
    });
  </script>

  <style>
    .media-page {
      padding-top: 80px;
    }

    .media-page .section {
      padding: 80px 0;
    }
    @media (max-width: 768px) {
      .media-page .section { padding: 50px 0; }
    }

    .eyebrow {
      font-family: 'Bebas Neue', 'Impact', sans-serif;
      font-size: 14px;
      letter-spacing: 0.18em;
      color: var(--primary);
      text-transform: uppercase;
      margin-bottom: 16px;
    }
    .eyebrow-light { color: var(--text-primary); }

    .section-heading-block {
      max-width: 720px;
      margin: 0 auto 48px;
      text-align: center;
    }
    .section-heading-block .eyebrow { display: block; }
    .section-title {
      font-size: clamp(32px, 4vw, 48px);
      font-family: 'Bebas Neue', 'Impact', sans-serif;
      letter-spacing: 0.04em;
      line-height: 1.05;
      color: var(--text-primary);
      margin-bottom: 18px;
      text-transform: uppercase;
    }
    .section-sub {
      color: var(--text-secondary);
      font-size: 16px;
      line-height: 1.7;
    }
    .inline-link {
      color: var(--primary);
      text-decoration: underline;
      text-decoration-thickness: 1px;
      text-underline-offset: 3px;
    }
    .inline-link:hover { color: var(--primary-light); }

    .media-hero {
      padding-top: 100px;
      background:
        radial-gradient(circle at 20% 0%, rgba(255, 0, 255, 0.18), transparent 55%),
        radial-gradient(circle at 80% 50%, rgba(255, 0, 255, 0.10), transparent 60%),
        linear-gradient(160deg, #141620, #181b22 40%, #141620);
    }
    .media-hero-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: center;
    }
    @media (max-width: 980px) {
      .media-hero-grid { grid-template-columns: 1fr; gap: 40px; }
    }

    .media-hero-text .main-title {
      font-size: clamp(42px, 5.5vw, 72px);
      letter-spacing: 0.02em;
      line-height: 1;
      color: var(--text-primary);
      margin-bottom: 24px;
      text-transform: uppercase;
    }
    .media-hero-text .hero-body {
      color: var(--text-secondary);
      font-size: 17px;
      line-height: 1.7;
      margin-bottom: 32px;
      max-width: 540px;
    }

    .hero-cta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
    }
    .cta-button {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 14px 28px;
      font-family: 'Bebas Neue', 'Impact', sans-serif;
      font-size: 16px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border-radius: 4px;
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }
    .primary-cta {
      background: var(--primary);
      color: #fff;
      box-shadow: var(--glow);
    }
    .primary-cta:hover {
      transform: translateY(-2px);
      background: var(--primary-light);
      box-shadow: var(--glow-strong);
      color: #fff;
    }
    .secondary-cta {
      background: rgba(255, 0, 255, 0.10);
      color: var(--text-primary);
      border: 1px solid rgba(255, 0, 255, 0.45);
    }
    .secondary-cta:hover {
      background: rgba(255, 0, 255, 0.20);
      border-color: rgba(255, 0, 255, 0.85);
      color: var(--text-primary);
      transform: translateY(-2px);
    }

    .trailer-card {
      display: block;
      width: 100%;
      background: var(--bg-card);
      border: 1px solid rgba(255, 0, 255, 0.30);
      border-radius: 8px;
      overflow: hidden;
      cursor: pointer;
      padding: 0;
      text-align: left;
      color: inherit;
      font: inherit;
      transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    }
    .trailer-card:hover {
      transform: translateY(-4px);
      border-color: rgba(255, 0, 255, 0.70);
      box-shadow: 0 12px 40px rgba(255, 0, 255, 0.25), 0 0 28px rgba(255, 0, 255, 0.18);
    }
    .trailer-card:focus-visible {
      outline: 2px solid var(--primary);
      outline-offset: 4px;
    }
    .trailer-thumb-wrap {
      position: relative;
      aspect-ratio: 16 / 9;
      background: #0d0f14;
      overflow: hidden;
    }
    .trailer-thumb {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.3s ease;
    }
    .trailer-card:hover .trailer-thumb { transform: scale(1.04); }
    .trailer-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(180deg, rgba(0,0,0,0) 30%, rgba(0,0,0,0.55) 100%);
      pointer-events: none;
    }
    .trailer-play-glow {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      width: 84px; height: 84px;
      border-radius: 50%;
      background: var(--primary);
      display: flex; align-items: center; justify-content: center;
      color: #fff;
      box-shadow: 0 0 24px rgba(255, 0, 255, 0.65), 0 0 48px rgba(255, 0, 255, 0.35);
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      pointer-events: none;
    }
    .trailer-play-glow svg { width: 36px; height: 36px; margin-left: 4px; }
    .trailer-card:hover .trailer-play-glow {
      transform: translate(-50%, -50%) scale(1.08);
      box-shadow: 0 0 30px rgba(255, 0, 255, 0.85), 0 0 60px rgba(255, 0, 255, 0.45);
    }
    .trailer-badge {
      position: absolute;
      top: 14px; left: 14px;
      background: rgba(15, 17, 22, 0.85);
      color: var(--primary);
      padding: 4px 10px;
      border: 1px solid rgba(255, 0, 255, 0.55);
      border-radius: 3px;
      font-family: 'Bebas Neue', 'Impact', sans-serif;
      font-size: 12px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    .trailer-meta {
      padding: 18px 20px 22px;
    }
    .trailer-title {
      font-family: 'Bebas Neue', 'Impact', sans-serif;
      font-size: 22px;
      letter-spacing: 0.04em;
      color: var(--text-primary);
      margin-bottom: 8px;
      text-transform: uppercase;
    }
    .trailer-desc {
      color: var(--text-secondary);
      font-size: 14px;
      line-height: 1.55;
    }

    .media-episodes {
      background: linear-gradient(180deg, #181b22 0%, #141620 100%);
    }
    .episodes-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 28px;
    }
    .episode-card {
      background: var(--bg-card);
      border: 1px solid rgba(255, 0, 255, 0.25);
      border-radius: 6px;
      overflow: hidden;
      transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    }
    .episode-card.is-playable:hover {
      transform: translateY(-4px);
      border-color: rgba(255, 0, 255, 0.65);
      box-shadow: 0 8px 28px rgba(255, 0, 255, 0.20);
    }
    .episode-card.is-coming-soon { opacity: 0.92; }
    .episode-card.is-coming-soon:hover {
      border-color: rgba(255, 0, 255, 0.42);
    }
