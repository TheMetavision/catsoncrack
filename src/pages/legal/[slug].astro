---
import type { GetStaticPaths } from 'astro'
import { client as sanityClient } from '../../lib/sanity'
import { PortableText } from 'astro-portabletext'
import Layout from '../../layouts/Layout.astro'
import Navigation from '../../components/Navigation.astro'
import Footer from '../../components/Footer.astro'

export const getStaticPaths: GetStaticPaths = async () => {
  const pages = await sanityClient.fetch(`*[_type == "legalPage" && defined(slug.current)]{ slug }`)
  return pages.map((p: any) => ({ params: { slug: p.slug.current } }))
}

const { slug } = Astro.params

const page = await sanityClient.fetch(`*[_type == "legalPage" && slug.current == $slug][0]{
  _id, title, summary, effectiveDate, lastUpdated, body, noIndex
}`, { slug })

if (!page) return Astro.redirect('/404')

const siblings = await sanityClient.fetch(`*[_type == "legalPage" && slug.current != $slug] | order(order asc){ title, slug }`, { slug })

const fmt = (iso: string) => new Date(iso).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })
---

<Layout title={`${page.title} · Cats On Crack`} description={page.summary} noIndex={page.noIndex}>
  <Navigation />
  <main class="legal-main">
    <article class="legal">
      <header class="legal__header">
        <p class="legal__eyebrow">Legal</p>
        <h1 class="legal__title">{page.title}</h1>
        {page.summary && <p class="legal__summary">{page.summary}</p>}
        <dl class="legal__meta">
          <div><dt>Effective</dt><dd>{fmt(page.effectiveDate)}</dd></div>
          <div><dt>Last updated</dt><dd>{fmt(page.lastUpdated)}</dd></div>
        </dl>
      </header>
      <div class="legal__body"><PortableText value={page.body} /></div>
      {siblings.length > 0 && (
        <nav class="legal__siblings" aria-label="Other legal pages">
          <h2>Other legal pages</h2>
          <ul>{siblings.map((s: any) => (<li><a href={`/legal/${s.slug.current}`}>{s.title}</a></li>))}</ul>
        </nav>
      )}
    </article>
  </main>
  <Footer />
</Layout>

<style>
  .legal-main {
    background: var(--charcoal);
    min-height: 60vh;
  }
  .legal {
    max-width: 760px;
    margin: 0 auto;
    padding: 8rem 1.25rem 6rem;
    color: #e5e5e5;
  }
  .legal__header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 0, 255, 0.18);
  }
  .legal__eyebrow {
    font-family: "Bebas Neue", sans-serif;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 5px;
    color: #ff00ff;
    margin: 0 0 0.75rem;
    text-shadow: 0 0 10px rgba(255, 0, 255, 0.4);
  }
  .legal__title {
    font-family: "Bebas Neue", sans-serif;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    line-height: 1.05;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 0 1rem;
    color: #ffffff;
  }
  .legal__summary {
    font-size: 1.1rem;
    color: #b0b0b0;
    margin: 0 0 1.5rem;
    line-height: 1.6;
  }
  .legal__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    margin: 0;
    font-size: 0.875rem;
  }
  .legal__meta dt {
    font-family: "Bebas Neue", sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.7rem;
    color: rgba(255, 0, 255, 0.55);
    margin-bottom: 0.25rem;
  }
  .legal__meta dd {
    margin: 0;
    font-weight: 600;
    color: #e5e5e5;
  }
  .legal__body {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: #d0d0d0;
  }
  .legal__body :global(h2) {
    font-family: "Bebas Neue", sans-serif;
    font-size: 1.6rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.25;
    color: #ffffff;
  }
  .legal__body :global(h3) {
    font-family: "Bebas Neue", sans-serif;
    font-size: 1.25rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
    color: #ffffff;
  }
  .legal__body :global(p) {
    margin: 0 0 1rem;
  }
  .legal__body :global(strong) {
    color: #ffffff;
  }
  .legal__body :global(ul),
  .legal__body :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.25rem;
  }
  .legal__body :global(li) {
    margin-bottom: 0.4rem;
  }
  .legal__body :global(a) {
    color: #ff00ff;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s ease, text-shadow 0.2s ease;
  }
  .legal__body :global(a:hover) {
    color: #ff66ff;
    text-shadow: 0 0 8px rgba(255, 0, 255, 0.4);
  }
  .legal__body :global(blockquote) {
    border-left: 3px solid #ff00ff;
    padding: 0.75rem 1.25rem;
    margin: 1.25rem 0;
    background: rgba(255, 0, 255, 0.06);
    font-style: italic;
  }
  .legal__body :global(code) {
    background: rgba(255, 255, 255, 0.06);
    padding: 0.1em 0.35em;
    border-radius: 3px;
    font-size: 0.92em;
    color: #ff66ff;
  }
  .legal__siblings {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 0, 255, 0.18);
  }
  .legal__siblings h2 {
    font-family: "Bebas Neue", sans-serif;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 5px;
    color: rgba(255, 0, 255, 0.55);
    margin: 0 0 1rem;
  }
  .legal__siblings ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
  }
  .legal__siblings a {
    color: #b0b0b0;
    text-decoration: none;
    border-bottom: 1px solid rgba(176, 176, 176, 0.3);
    padding-bottom: 1px;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .legal__siblings a:hover {
    color: #ff00ff;
    border-bottom-color: #ff00ff;
  }
</style>
