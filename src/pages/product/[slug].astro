---
/**
 * src/pages/product/[slug].astro  (Cats On Crack — NESTED model)
 *
 * Static (getStaticPaths). Size availability is driven by the printfulVariants
 * matrix PER SELECTED COLOUR — so a colour that Printful doesn't offer in a
 * given size never shows that size, which prevents the checkout 422
 * ("temporarily unavailable") that happens when a colour+size combo has no
 * Printful sync variant. Images fall back to colourImages when the variant
 * has no printfulImageUrl. Add-to-cart dispatches the event CartDrawer reads:
 *   { id: '{_id}-{type}-{colour}-{size}', title, price, size, colour, image, productType }
 */
import Layout from '../../layouts/Layout.astro';
import { getAllProducts, getProductBySlug } from '../../lib/sanity';

export async function getStaticPaths() {
  const products = await getAllProducts();
  return products.map((p) => ({ params: { slug: p.slug }, props: { product: p } }));
}

const { product } = Astro.props;
const design = product ?? (await getProductBySlug(Astro.params.slug || ''));
const defaultVariant = design.variants?.[0];

/* Variant has no printfulImageUrl in COC data — fall back to first colour mockup */
const variantImg = (v) => v?.printfulImageUrl || v?.colourImages?.[0]?.imageUrl || '';

/* Serialise variants for the client island. We pass the matrix (size+colour)
   so the client can show only sizes that actually exist for the chosen colour. */
const variantsJson = JSON.stringify(
  (design.variants || []).map((v) => ({
    type: v.productType,
    label: v.label,
    basePrice: v.basePrice,
    sizePrices: v.sizePrices || [],
    colourImages: (v.colourImages || []).map((ci) => ({ colour: ci.colour, imageUrl: ci.imageUrl })),
    matrix: (v.printfulVariants || []).map((pv) => ({ size: pv.size, colour: pv.colour || '' })),
    thumbnail: variantImg(v),
  }))
);
---

<Layout title={`${design.name} — Cats On Crack`} description={design.backstory || design.tagline}>
  <main class="pdp" style={`--accent: ${design.accent || '#FF00FF'};`}>
    <div class="pdp-grid">
      <!-- Gallery -->
      <div class="pdp-gallery">
        <div class="pdp-main">
          <img id="pdp-hero" src={variantImg(defaultVariant)} alt={`${design.name} ${defaultVariant?.label}`} />
          <span class="pdp-zoom-hint" aria-hidden="true">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
            Zoom
          </span>
        </div>
        <div class="pdp-thumbs">
          {design.variants?.map((v, i) => (
            <button class={`pdp-thumb ${i === 0 ? 'active' : ''}`} data-type={v.productType} title={v.label}>
              <img src={variantImg(v)} alt={`${design.name} ${v.label}`} loading="lazy" />
            </button>
          ))}
        </div>
      </div>

      <!-- Info -->
      <div class="pdp-info">
        <a href="/merch" class="pdp-back">&larr; Back to shop</a>
        <h1 class="pdp-title">{design.name}</h1>
        {design.tagline && <p class="pdp-tagline">{design.tagline}</p>}

        <div class="pdp-types">
          {design.variants?.map((v, i) => (
            <button class={`pdp-type ${i === 0 ? 'active' : ''}`} data-type={v.productType}>{v.label}</button>
          ))}
        </div>

        <p class="pdp-price" id="pdp-price">&pound;{defaultVariant?.basePrice?.toFixed(2)}</p>
        {design.backstory && <p class="pdp-backstory">{design.backstory}</p>}

        <div class="pdp-field" id="colour-wrap">
          <span class="pdp-field-label">Colour <span id="colour-name" class="pdp-colour-name"></span></span>
          <select id="colour-select"></select>
        </div>

        <div class="pdp-field">
          <span class="pdp-field-label">Size</span>
          <div class="pdp-sizes" id="size-options"></div>
        </div>

        <button class="pdp-add" id="add-to-cart-btn">
          <span class="t-default">Add to cart</span>
          <span class="t-added" style="display:none;">Added!</span>
        </button>

        {design.designStory && (
          <div class="pdp-story"><h2>The story</h2><p>{design.designStory}</p></div>
        )}
      </div>
    </div>

    <!-- Zoom lightbox -->
    <div class="pdp-lightbox" id="pdp-lightbox" aria-hidden="true">
      <button class="pdp-lightbox-close" id="pdp-lightbox-close" aria-label="Close">&times;</button>
      <img id="pdp-lightbox-img" src="" alt={design.name} />
    </div>
  </main>

  <script define:vars={{ designId: design._id, designName: design.name, variantsJson, defaultType: defaultVariant?.productType || '' }}>
    const variants = JSON.parse(variantsJson);
    const qp = new URLSearchParams(window.location.search).get('type');
    let currentType = (qp && variants.some((v) => v.type === qp)) ? qp : defaultType;
    let selectedColour = '';
    let selectedSize = '';
    let currentPrice = 0;

    const SIZE_ORDER = ['XS','S','M','L','XL','2XL','3XL','4XL','5XL','One Size',
      '11 oz','15 oz','16 oz','16 oz With Lid & Straw','20oz','20 oz'];
    const sizeRank = (s) => { const i = SIZE_ORDER.indexOf(s); return i === -1 ? 999 : i; };

    const heroEl = document.getElementById('pdp-hero');
    const priceEl = document.getElementById('pdp-price');
    const colourWrap = document.getElementById('colour-wrap');
    const colourSelect = document.getElementById('colour-select');
    const colourName = document.getElementById('colour-name');
    const sizeBox = document.getElementById('size-options');
    const addBtn = document.getElementById('add-to-cart-btn');

    const getVariant = () => variants.find((v) => v.type === currentType) || variants[0];

    function priceForSize(variant, size) {
      const sp = (variant.sizePrices || []).find((s) => s.size === size);
      return sp ? sp.price : variant.basePrice;
    }
    function imageForColour(variant, colour) {
      const ci = (variant.colourImages || []).find((c) => c.colour === colour);
      return ci?.imageUrl || variant.thumbnail;
    }
    /* Colours that actually have at least one matrix entry (so every offered
       colour has at least one buyable size) */
    function coloursFor(variant) {
      const inMatrix = new Set((variant.matrix || []).map((m) => m.colour));
      let opts = (variant.colourImages || []).map((c) => c.colour).filter((c) => inMatrix.has(c));
      if (!opts.length) opts = [...inMatrix];
      return opts;
    }
    /* Sizes available for THIS colour, ordered */
    function sizesFor(variant, colour) {
      const set = new Set((variant.matrix || []).filter((m) => m.colour === colour).map((m) => m.size));
      return [...set].sort((a, b) => sizeRank(a) - sizeRank(b));
    }

    function renderColours(variant) {
      const opts = coloursFor(variant);
      const colourless = opts.length <= 1 && !opts[0];
      if (colourless) {
        colourWrap.style.display = 'none';
        selectedColour = opts[0] || '';
        return;
      }
      colourWrap.style.display = '';
      const keep = opts.includes(selectedColour) ? selectedColour : opts[0];
      colourSelect.innerHTML = opts.map((c) => `<option value="${c}"${c === keep ? ' selected' : ''}>${c}</option>`).join('');
      selectedColour = keep;
      if (colourName) colourName.textContent = '';
    }

    function renderSizes(variant) {
      const sizes = sizesFor(variant, selectedColour);
      const keep = sizes.includes(selectedSize) ? selectedSize : sizes[0];
      sizeBox.innerHTML = sizes.map((s) => {
        const long = /\s/.test(s) ? ' long' : '';
        return `<button class="pdp-size${long}${s === keep ? ' active' : ''}" data-size="${s}">${s}</button>`;
      }).join('');
      selectedSize = keep || '';
      sizeBox.querySelectorAll('.pdp-size').forEach((btn) => {
        btn.addEventListener('click', () => {
          sizeBox.querySelectorAll('.pdp-size').forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          selectedSize = btn.dataset.size;
          updatePrice();
        });
      });
    }
    function updatePrice() {
      currentPrice = priceForSize(getVariant(), selectedSize);
      if (priceEl) priceEl.textContent = `£${(currentPrice || 0).toFixed(2)}`;
    }
    function updateHero() {
      if (heroEl) heroEl.src = imageForColour(getVariant(), selectedColour);
    }
    function selectType(type) {
      currentType = type;
      const v = getVariant();
      document.querySelectorAll('.pdp-type').forEach((b) => b.classList.toggle('active', b.dataset.type === type));
      document.querySelectorAll('.pdp-thumb').forEach((b) => b.classList.toggle('active', b.dataset.type === type));
      renderColours(v);
      renderSizes(v);
      updateHero();
      updatePrice();
    }

    document.querySelectorAll('.pdp-type').forEach((b) => b.addEventListener('click', () => selectType(b.dataset.type)));
    document.querySelectorAll('.pdp-thumb').forEach((b) => b.addEventListener('click', () => selectType(b.dataset.type)));
    colourSelect?.addEventListener('change', () => {
      selectedColour = colourSelect.value;
      renderSizes(getVariant());   // sizes depend on colour
      updateHero();
      updatePrice();
    });

    addBtn?.addEventListener('click', () => {
      if (!selectedSize) return;
      const v = getVariant();
      window.dispatchEvent(new CustomEvent('add-to-cart', { detail: {
        id: `${designId}-${currentType}-${selectedColour}-${selectedSize}`,
        title: `${designName} ${v?.label || ''}`.trim(),
        price: currentPrice,
        size: selectedSize,
        colour: selectedColour,
        image: imageForColour(v, selectedColour),
        productType: currentType,
      }}));
      const def = addBtn.querySelector('.t-default'), added = addBtn.querySelector('.t-added');
      if (def) def.style.display = 'none';
      if (added) added.style.display = 'inline';
      setTimeout(() => { if (def) def.style.display = 'inline'; if (added) added.style.display = 'none'; }, 1500);
    });

    /* init */
    selectType(currentType);
  </script>

  <script>
    /* Image zoom: desktop hover-magnify on the main image + tap/click lightbox
       with pinch-free zoom & pan (works on touch). Reads #pdp-hero's CURRENT
       src at open time, so it always reflects the selected colour/variant. */
    (() => {
      const main = document.querySelector('.pdp-main');
      const hero = document.getElementById('pdp-hero');
      if (!main || !hero) return;

      /* ---- Desktop hover magnify ---- */
      const fine = window.matchMedia('(pointer: fine)').matches;
      const HOVER_SCALE = 2.4;
      if (fine) {
        main.addEventListener('mousemove', (e) => {
          const r = main.getBoundingClientRect();
          const x = ((e.clientX - r.left) / r.width) * 100;
          const y = ((e.clientY - r.top) / r.height) * 100;
          hero.style.transformOrigin = `${x}% ${y}%`;
          hero.style.transform = `scale(${HOVER_SCALE})`;
        });
        main.addEventListener('mouseleave', () => {
          hero.style.transform = '';
          hero.style.transformOrigin = '';
        });
      }

      /* ---- Lightbox ---- */
      const lb = document.getElementById('pdp-lightbox');
      const lbImg = document.getElementById('pdp-lightbox-img');
      const lbClose = document.getElementById('pdp-lightbox-close');
      if (!lb || !lbImg) return;

      const SCALE = 2.4;
      let zoomed = false, panX = 0, panY = 0, startX = 0, startY = 0, dragging = false, moved = false;

      function clamp() {
        const maxX = (lbImg.clientWidth * (SCALE - 1)) / 2;
        const maxY = (lbImg.clientHeight * (SCALE - 1)) / 2;
        panX = Math.max(-maxX, Math.min(maxX, panX));
        panY = Math.max(-maxY, Math.min(maxY, panY));
      }
      function apply() {
        if (zoomed) clamp();
        lbImg.style.transform = zoomed
          ? `translate(${panX}px, ${panY}px) scale(${SCALE})`
          : 'translate(0,0) scale(1)';
      }
      function openLB() {
        hero.style.transform = '';
        hero.style.transformOrigin = '';
        lbImg.src = hero.src;
        zoomed = false; panX = 0; panY = 0;
        lb.classList.remove('zoomed', 'dragging');
        apply();
        lb.classList.add('open');
        lb.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }
      function closeLB() {
        lb.classList.remove('open');
        lb.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }

      main.addEventListener('click', openLB);
      lbClose?.addEventListener('click', closeLB);
      lb.addEventListener('click', (e) => { if (e.target === lb) closeLB(); });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && lb.classList.contains('open')) closeLB();
      });

      lbImg.addEventListener('pointerdown', (e) => {
        e.preventDefault();
        dragging = true; moved = false;
        startX = e.clientX - panX; startY = e.clientY - panY;
        lb.classList.add('dragging');
        lbImg.setPointerCapture?.(e.pointerId);
      });
      lbImg.addEventListener('pointermove', (e) => {
        if (!dragging || !zoomed) return;
        panX = e.clientX - startX; panY = e.clientY - startY;
        moved = true; apply();
      });
      function endDrag(e) {
        if (!dragging) return;
        dragging = false;
        lb.classList.remove('dragging');
        if (!moved) {
          if (!zoomed) {
            const r = lbImg.getBoundingClientRect();
            const cx = e.clientX - (r.left + r.width / 2);
            const cy = e.clientY - (r.top + r.height / 2);
            zoomed = true;
            lb.classList.add('zoomed');
            panX = -cx * (SCALE - 1);
            panY = -cy * (SCALE - 1);
          } else {
            zoomed = false;
            lb.classList.remove('zoomed');
            panX = 0; panY = 0;
          }
          apply();
        }
      }
      lbImg.addEventListener('pointerup', endDrag);
      lbImg.addEventListener('pointercancel', endDrag);
    })();
  </script>

  <style>
    .pdp { max-width: 1100px; margin: 0 auto; padding: 5rem 1.5rem; color: #F0EDE8; }
    .pdp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; }
    .pdp-main { position: relative; aspect-ratio: 1; background: #1f2330; border: 1px solid #ffffff1f; border-radius: 10px; overflow: hidden; cursor: zoom-in; }
    .pdp-main img { width: 100%; height: 100%; object-fit: cover; transition: transform .12s ease-out; will-change: transform; }

    /* Zoom hint badge */
    .pdp-zoom-hint { position: absolute; right: 10px; bottom: 10px; display: flex; align-items: center; gap: 5px; padding: 5px 9px; background: rgba(0,0,0,.55); color: #fff; font-family: 'Bebas Neue', sans-serif; font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; border-radius: 4px; pointer-events: none; opacity: .85; transition: opacity .15s ease; }
    .pdp-main:hover .pdp-zoom-hint { opacity: 0; }

    /* Zoom lightbox */
    .pdp-lightbox { position: fixed; inset: 0; z-index: 9999; display: none; align-items: center; justify-content: center; background: rgba(8,8,12,.93); }
    .pdp-lightbox.open { display: flex; }
    .pdp-lightbox img { max-width: 92vw; max-height: 92vh; object-fit: contain; border-radius: 6px; cursor: zoom-in; touch-action: none; user-select: none; -webkit-user-drag: none; transition: transform .15s ease; }
    .pdp-lightbox.zoomed img { cursor: grab; transition: none; }
    .pdp-lightbox.dragging img { cursor: grabbing; }
    .pdp-lightbox-close { position: fixed; top: 16px; right: 20px; width: 42px; height: 42px; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.25); color: #fff; font-size: 24px; line-height: 1; border-radius: 50%; cursor: pointer; transition: all .15s ease; }
    .pdp-lightbox-close:hover { background: var(--accent); color: #000; border-color: var(--accent); }
    .pdp-thumbs { display: flex; gap: 8px; margin-top: 12px; flex-wrap: wrap; }
    .pdp-thumb { width: 64px; height: 64px; border-radius: 6px; overflow: hidden; border: 2px solid transparent; background: #1f2330; cursor: pointer; padding: 0; }
    .pdp-thumb.active { border-color: var(--accent); }
    .pdp-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .pdp-back { color: #8a8880; text-decoration: none; font-size: 14px; }
    .pdp-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.2rem, 4vw, 3rem); letter-spacing: 1px; margin: 0.5rem 0 0.25rem; text-transform: uppercase; }
    .pdp-tagline { color: var(--accent); font-weight: 600; margin: 0 0 1rem; }
    .pdp-types { display: flex; gap: 8px; flex-wrap: wrap; margin: 1rem 0; }
    .pdp-type { font-family: 'Bebas Neue', sans-serif; padding: 8px 16px; background: #1a1d2e; color: #F0EDE8; border: 1px solid rgba(255,0,255,0.25); border-radius: 4px; cursor: pointer; font-size: 1rem; letter-spacing: 1px; text-transform: uppercase; transition: all .15s ease; }
    .pdp-type:hover { border-color: var(--accent); color: var(--accent); }
    .pdp-type.active { background: var(--accent); border-color: var(--accent); color: #000; }
    .pdp-price { font-family: 'Bebas Neue', sans-serif; font-size: 2.25rem; letter-spacing: 1px; color: var(--accent); margin: 0.5rem 0 1rem; }
    .pdp-backstory { color: #b8b5ad; line-height: 1.6; }
    .pdp-field { margin: 1.5rem 0; }
    .pdp-field-label { display: block; font-family: 'Bebas Neue', sans-serif; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 2px; color: #8a8880; margin-bottom: 10px; }
    #colour-select { width: 100%; max-width: 280px; padding: 11px 12px; background: #1a1d2e; color: #F0EDE8; border: 1px solid rgba(255,0,255,0.25); border-radius: 4px; font-size: 14px; }
    #colour-select:focus { outline: none; border-color: var(--accent); }
    /* Size pills are styled in the is:global block below. They're injected
       client-side via innerHTML, so they don't get Astro's scoped hash and
       scoped .pdp-size rules would never match them. */
    .pdp-sizes { display: flex; gap: 10px; flex-wrap: wrap; }
    .pdp-add { font-family: 'Bebas Neue', sans-serif; width: 100%; max-width: 360px; margin-top: 1.5rem; padding: 15px; background: var(--accent); color: #000; border: none; border-radius: 4px; text-transform: uppercase; letter-spacing: 3px; cursor: pointer; font-size: 1.2rem; }
    .pdp-add:hover { filter: brightness(1.08); }
    .pdp-add:hover { filter: brightness(1.08); }
    .pdp-story { margin-top: 2rem; border-top: 1px solid #ffffff14; padding-top: 1.5rem; }
    .pdp-story h2 { font-size: 1rem; text-transform: uppercase; letter-spacing: 1px; color: #8a8880; }
    @media (max-width: 768px) { .pdp-grid { grid-template-columns: 1fr; } }
  </style>

  <style is:global>
    /* #size-options is server-rendered (so it carries the page hash), but its
       child .pdp-size buttons are injected via innerHTML and would otherwise be
       unstyled. Keyed on the unique #size-options id so it stays contained.
       var(--accent) still resolves — it's inherited from the .pdp ancestor. */
    #size-options .pdp-size {
      font-family: 'Bebas Neue', sans-serif;
      min-width: 52px; padding: 11px 16px; background: #1a1d2e; color: #F0EDE8;
      border: 1px solid rgba(255, 0, 255, 0.25); border-radius: 4px; cursor: pointer;
      font-size: 1.05rem; letter-spacing: 1px; line-height: 1; text-align: center;
      text-transform: uppercase; white-space: nowrap; transition: all .15s ease;
    }
    #size-options .pdp-size:hover { border-color: var(--accent); color: var(--accent); }
    #size-options .pdp-size.active { background: var(--accent); border-color: var(--accent); color: #000; }
    #size-options .pdp-size.long { white-space: normal; max-width: 150px; font-size: 0.8rem; letter-spacing: 0; text-transform: none; line-height: 1.2; padding: 9px 12px; }
  </style>
</Layout>
