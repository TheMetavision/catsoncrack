---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import SectionDivider from '../components/SectionDivider.astro';
---

<Layout title="Cats On Crack - The Wildest Alley Cats You'll Ever Meet">
	<Navigation />

	<main>
		<section class="hero">
			<div class="hero-urban-bg"></div>
			<div class="hero-grain"></div>

			<div class="hero-split container">
				<div class="hero-image-col fade-left hero-anim-immediate">
					<div class="character-carousel" id="heroCarousel">

						<div class="carousel-slide active" data-index="0">
							<div class="character-frame">
								<img
									src="https://assets.zyrosite.com/cdn-cgi/image/format=auto,w=1024,h=1275,fit=crop/YanqXRJ3EDIXPJ8q/d700a221-efab-493b-94b1-5bc213c72b36-mp8qZRbbzEiL6R2D.png"
									alt="Toothless Terry"
									class="hero-character"
									loading="eager"
									fetchpriority="high"
								/>
								<div class="character-ground-vignette"></div>
								<div class="character-nameplate">
									<div class="nameplate-name">Toothless Terry</div>
									<div class="nameplate-role">The Scheme Engine</div>
								</div>
								<div class="character-tagline">"Here's the thing about problems, pal — a problem is just a deal that hasn't been structured yet."</div>
							</div>
						</div>

						<div class="carousel-slide" data-index="1">
							<div class="character-frame">
								<img
									src="https://cdn.sanity.io/images/8ksun996/production/d96725d0e76a478fea8c4cab6f210bab4367d0f9-896x1344.png"
									alt="Whiskers McScruff"
									class="hero-character"
									style="max-width: 360px;"
									loading="lazy"
								/>
								<div class="character-ground-vignette"></div>
								<div class="character-nameplate">
									<div class="nameplate-name">Whiskers McScruff</div>
									<div class="nameplate-role">The Leader</div>
								</div>
								<div class="character-tagline">"Chaos is the cure. I've said it before. I've said it to the bins. The bins agree with me."</div>
							</div>
						</div>

						<div class="carousel-slide" data-index="2">
							<div class="character-frame">
								<img
									src="https://cdn.sanity.io/images/8ksun996/production/87fee4d99ed54660972e1f7253091a621f4d4d24-896x1344.png"
									alt="Luna the Loner"
									class="hero-character"
									loading="lazy"
								/>
								<div class="character-ground-vignette"></div>
								<div class="character-nameplate">
									<div class="nameplate-name">Luna the Loner</div>
									<div class="nameplate-role">The Ghost</div>
								</div>
								<div class="character-tagline">"I don't have opinions about your plan. I have information."</div>
							</div>
						</div>

						<div class="carousel-slide" data-index="3">
							<div class="character-frame">
								<img
									src="https://cdn.sanity.io/images/8ksun996/production/e1ed30a067bbe4cff4f6b4962859557dd7fa103a-896x1344.png"
									alt="Chubby Cheeks"
									class="hero-character"
									loading="lazy"
								/>
								<div class="character-ground-vignette"></div>
								<div class="character-nameplate">
									<div class="nameplate-name">Chubby Cheeks</div>
									<div class="nameplate-role">The Muscle</div>
								</div>
								<div class="character-tagline">"You don't just find snacks. You earn them. And by 'earn,' I mean you take them from the weak."</div>
							</div>
						</div>

						<div class="carousel-slide" data-index="4">
							<div class="character-frame">
								<img
									src="https://cdn.sanity.io/images/8ksun996/production/2058d4f4b5dff10ada3007a9c58828708cf2d685-896x1344.png"
									alt="Gizmo the Genius"
									class="hero-character"
									loading="lazy"
								/>
								<div class="character-ground-vignette"></div>
								<div class="character-nameplate">
									<div class="nameplate-name">Gizmo the Genius</div>
									<div class="nameplate-role">The Inventor</div>
								</div>
								<div class="character-tagline">"Now, the beautiful thing about this is — oh, that's interesting. Actually, everyone move."</div>
							</div>
						</div>

						<div class="carousel-slide" data-index="5">
							<div class="character-frame">
								<img
									src="https://cdn.sanity.io/images/8ksun996/production/e323f904272aa43242549c2743913bdc24cb755c-896x1344.png"
									alt="Trixie the Trickster"
									class="hero-character"
									loading="lazy"
								/>
								<div class="character-ground-vignette"></div>
								<div class="character-nameplate">
									<div class="nameplate-name">Trixie the Trickster</div>
									<div class="nameplate-role">The Artist</div>
								</div>
								<div class="character-tagline">"I don't make mistakes. I make unexpectedly vivid decisions."</div>
							</div>
						</div>

						<button class="carousel-arrow carousel-prev" id="carouselPrev" aria-label="Previous character">&#8592;</button>
						<button class="carousel-arrow carousel-next" id="carouselNext" aria-label="Next character">&#8594;</button>

						<div class="carousel-dots" id="carouselDots">
							<button class="carousel-dot active" data-dot="0" aria-label="Slide 1"></button>
							<button class="carousel-dot" data-dot="1" aria-label="Slide 2"></button>
							<button class="carousel-dot" data-dot="2" aria-label="Slide 3"></button>
							<button class="carousel-dot" data-dot="3" aria-label="Slide 4"></button>
							<button class="carousel-dot" data-dot="4" aria-label="Slide 5"></button>
							<button class="carousel-dot" data-dot="5" aria-label="Slide 6"></button>
						</div>
					</div>
				</div>

				<div class="hero-text-col fade-right hero-anim-immediate">
					<div class="eyebrow">Now Streaming</div>
					<h1 class="main-title">The Wildest Alley Cats<br>You'll Ever Meet</h1>
					<p class="hero-body">A crew of street-savvy misfit cats. Rival gangs. Dark alleys. Glowing pipes. This is <strong>Cats On Crack</strong> — and they don't play by anyone's rules.</p>
					<div class="hero-ctas">
						<a href="https://www.youtube.com/shorts/ay215yKvntY" target="_blank" rel="noopener" class="cta-button primary-cta">
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M8 5v14l11-7z"/></svg>
							Watch Our Trailer
						</a>
						<a href="/the-alley-squad" class="cta-button secondary-cta">
							Meet the Squad
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/></svg>
						</a>
					</div>
					<div class="hero-stats stagger-children">
						<div class="stat">
							<span class="stat-number" data-count="5" data-suffix="+">5+</span>
							<span class="stat-label">Characters</span>
						</div>
						<div class="stat-divider"></div>
						<div class="stat">
							<span class="stat-number">Series 1</span>
							<span class="stat-label">Now Live</span>
						</div>
						<div class="stat-divider"></div>
						<div class="stat">
							<span class="stat-number" data-count="100" data-suffix="%">100%</span>
							<span class="stat-label">Unfiltered</span>
						</div>
					</div>
				</div>
			</div>

			<div class="hero-bottom-fade"></div>
		</section>

		<SectionDivider variant="crack" />

		<section id="about" class="section universe-section">
			<div class="container">
				<div class="universe-header fade-up">
					<p class="universe-eyebrow">Explore</p>
					<h2 class="universe-heading">The Cats On Crack Universe</h2>
				</div>
				<div class="pillars fade-up">

					<div class="pillar">
						<div class="pillar-icon-wrap">
							<svg class="pillar-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
								<path d="M8 5v14l11-7z"/>
							</svg>
						</div>
						<div class="pillar-label">Watch</div>
						<h3 class="pillar-headline">Watch the Series</h3>
						<p class="pillar-copy">The animated series is live on YouTube. New episodes dropping — subscribe so you don't miss a thing.</p>
						<a href="https://www.youtube.com/@CatsOnCrackMedia" target="_blank" rel="noopener noreferrer" class="pillar-cta">Watch Now &rarr;</a>
					</div>

					<div class="pillar-divider"></div>

					<div class="pillar">
						<div class="pillar-icon-wrap">
							<svg class="pillar-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
								<path d="M21 5c-1.11-.35-2.33-.5-3.5-.5-1.95 0-4.05.4-5.5 1.5-1.45-1.1-3.55-1.5-5.5-1.5S2.45 4.9 1 6v14.65c0 .25.25.5.5.5.1 0 .15-.05.25-.05C3.1 20.45 5.05 20 6.5 20c1.95 0 4.05.4 5.5 1.5 1.35-.85 3.8-1.5 5.5-1.5 1.65 0 3.35.3 4.75 1.05.1.05.15.05.25.05.25 0 .5-.25.5-.5V6c-.6-.45-1.25-.75-2-1zm0 13.5c-1.1-.35-2.3-.5-3.5-.5-1.7 0-4.15.65-5.5 1.5V8c1.35-.85 3.8-1.5 5.5-1.5 1.2 0 2.4.15 3.5.5v11.5z"/>
							</svg>
						</div>
						<div class="pillar-label">Read</div>
						<h3 class="pillar-headline">Read the Comics</h3>
						<p class="pillar-copy">Multi-panel. Gritty. Unfiltered. The Cats On Crack comic series — issues coming soon.</p>
						<a href="/alleyway-gazette" class="pillar-cta">Explore the Gazette &rarr;</a>
					</div>

					<div class="pillar-divider"></div>

					<div class="pillar">
						<div class="pillar-icon-wrap">
							<svg class="pillar-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
								<path d="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.42l9 9c.36.36.86.58 1.41.58.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.42zM5.5 7C4.67 7 4 6.33 4 5.5S4.67 4 5.5 4 7 4.67 7 5.5 6.33 7 5.5 7z"/>
							</svg>
						</div>
						<div class="pillar-label">Rep</div>
						<h3 class="pillar-headline">Rep the Alley</h3>
						<p class="pillar-copy">Character apparel, prints, collectibles. The official COC merch store is dropping soon — get on the list.</p>
						<a href="/merch" class="pillar-cta">See What's Coming &rarr;</a>
					</div>

				</div>
			</div>
		</section>

		<SectionDivider variant="spray" />

		<section id="books" class="section books-section">
			<div class="container">
				<div class="content-split">
					<div class="image-side fade-left">
						<div class="image-card">
							<img
								src="https://assets.zyrosite.com/cdn-cgi/image/format=auto,w=768,h=915,fit=crop/YanqXRJ3EDIXPJ8q/d0bae9bd-dbc9-49ad-a286-efd5eede6ac5-A1aBEM9plKCW0Ol8.png"
								alt="Cats on Crack Book"
							/>
						</div>
					</div>
					<div class="text-side fade-right">
						<h2 class="section-title glow-text">Chaos, Claws, and Crack-Pipe Capers – The Ultimate Alley Adventure!</h2>
						<p>Dive into the gritty, hilarious world of <em>Cats on Crack</em>! This action-packed book series follows a crew of unpredictable alley cats as they hustle, brawl, and outsmart their rivals in the city's darkest corners. Fast-paced, wild, and full of twists—once you start, you won't stop!</p>
						<a href="/alleyway-gazette" class="cta-button secondary">Check Out Our Series</a>
					</div>
				</div>
			</div>
		</section>

		<SectionDivider variant="crack" flip={true} />

		<section id="characters" class="section characters-section">
			<div class="container">
				<div class="content-split reverse">
					<div class="text-side fade-left">
						<h2 class="section-title glow-text">Meet the Squad – The Wildest Cats in Town!</h2>
						<p>Get to know the misfit crew that rules the alley! From cunning masterminds to chaos-loving rogues, each cat brings their own brand of madness. Meet the legends, learn their stories, and see who's clawing their way to the top!</p>
						<a href="/the-alley-squad" class="cta-button secondary">Meet The Gang</a>
					</div>
					<div class="image-side fade-right">
						<div class="image-card">
							<img
								src="https://assets.zyrosite.com/cdn-cgi/image/format=auto,w=768,h=1014,fit=crop/YanqXRJ3EDIXPJ8q/93b19814-7a63-4180-b0a3-bd6b7b534cb8-mjEqlnbNMpslVaQr.png"
								alt="Cats on Crack Characters"
							/>
						</div>
					</div>
				</div>
			</div>
		</section>

		<SectionDivider variant="spray" flip={true} />

		<section id="newsletter" class="section newsletter-section">
			<div class="container">
				<div class="newsletter-content fade-up">
					<div class="newsletter-image">
						<img
							src="https://assets.zyrosite.com/cdn-cgi/image/format=auto,w=1024,h=1170,fit=crop/YanqXRJ3EDIXPJ8q/510cd283-5bfb-41c5-bda4-e2899b6276c4-YBge0Nwj37Fzjj43.png"
							alt="Newsletter"
						/>
					</div>
					<div class="newsletter-text">
						<h2 class="glow-text">Exclusive Alley Secrets, Sneaky Schemes & Feline Mayhem Delivered Weekly!</h2>
						<p class="subtitle">Subscribe to our newsletter</p>
						<form class="newsletter-form" id="newsletterForm">
							<input
								type="email"
								placeholder="Enter your email address"
								required
								aria-label="Email address"
								class="email-input"
							/>
							<button type="submit" class="cta-button">Subscribe</button>
						</form>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<style>
	/* Hero elements animate in on page load, not on scroll */
	.hero-anim-immediate {
		animation-fill-mode: both;
	}
	.hero-image-col.fade-left.hero-anim-immediate {
		animation: heroSlideLeft 0.9s cubic-bezier(0.22,1,0.36,1) 0.1s both;
	}
	.hero-text-col.fade-right.hero-anim-immediate {
		animation: heroSlideRight 0.9s cubic-bezier(0.22,1,0.36,1) 0.25s both;
	}
	@keyframes heroSlideLeft {
		from { opacity: 0; transform: translateX(-48px); }
		to   { opacity: 1; transform: translateX(0); }
	}
	@keyframes heroSlideRight {
		from { opacity: 0; transform: translateX(48px); }
		to   { opacity: 1; transform: translateX(0); }
	}

	.universe-section {
		background: #181b22;
	}

	.universe-header {
		text-align: center;
		margin-bottom: 60px;
	}

	.universe-eyebrow {
		font-family: 'Bebas Neue', sans-serif;
		font-size: 0.82rem;
		letter-spacing: 5px;
		color: #ff00ff;
		text-transform: uppercase;
		margin-bottom: 10px;
		opacity: 0.85;
	}

	.universe-heading {
		font-family: 'Bebas Neue', sans-serif;
		font-size: clamp(2.4rem, 5vw, 4rem);
		color: #ffffff;
		letter-spacing: 3px;
		line-height: 1;
		text-shadow:
			3px 3px 0 rgba(255,0,255,0.3),
			0 0 40px rgba(255,0,255,0.15);
	}

	.pillars {
		display: grid;
		grid-template-columns: 1fr auto 1fr auto 1fr;
		align-items: stretch;
		gap: 0;
		border: 1px solid rgba(255,0,255,0.15);
		border-radius: 4px;
		overflow: hidden;
	}

	.pillar {
		padding: 52px 44px 48px;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		background: rgba(255,255,255,0.015);
		transition: background 0.3s ease;
		position: relative;
	}

	.pillar::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 2px;
		background: linear-gradient(90deg, transparent, rgba(255,0,255,0.5), transparent);
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.pillar:hover {
		background: rgba(255,0,255,0.04);
	}

	.pillar:hover::before {
		opacity: 1;
	}

	.pillar-divider {
		width: 1px;
		background: linear-gradient(
			to bottom,
			transparent 0%,
			rgba(255,0,255,0.3) 20%,
			rgba(255,0,255,0.3) 80%,
			transparent 100%
		);
		flex-shrink: 0;
	}

	.pillar-icon-wrap {
		width: 64px;
		height: 64px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		background: rgba(255,0,255,0.1);
		border: 1px solid rgba(255,0,255,0.25);
		margin-bottom: 20px;
		transition: background 0.3s ease, box-shadow 0.3s ease;
	}

	.pillar:hover .pillar-icon-wrap {
		background: rgba(255,0,255,0.18);
		box-shadow: 0 0 24px rgba(255,0,255,0.2);
	}

	.pillar-icon {
		width: 26px;
		height: 26px;
		color: #ff00ff;
	}

	.pillar-label {
		font-family: 'Bebas Neue', sans-serif;
		font-size: 0.72rem;
		letter-spacing: 5px;
		color: rgba(255,0,255,0.65);
		text-transform: uppercase;
		margin-bottom: 14px;
	}

	.pillar-headline {
		font-family: 'Bebas Neue', sans-serif;
		font-size: clamp(1.6rem, 2.5vw, 2.1rem);
		letter-spacing: 2px;
		color: #ffffff;
		margin-bottom: 14px;
		line-height: 1;
	}

	.pillar-copy {
		font-size: 0.95rem;
		line-height: 1.7;
		color: rgba(200,195,190,0.7);
		margin-bottom: 28px;
		flex: 1;
	}

	.pillar-cta {
		font-family: 'Bebas Neue', sans-serif;
		font-size: 0.9rem;
		letter-spacing: 2px;
		color: #ff00ff;
		text-decoration: none;
		border-bottom: 1px solid rgba(255,0,255,0.35);
		padding-bottom: 2px;
		transition: color 0.2s ease, border-color 0.2s ease, text-shadow 0.2s ease;
	}

	.pillar-cta:hover {
		color: #ffffff;
		border-color: rgba(255,255,255,0.5);
		text-shadow: 0 0 10px rgba(255,0,255,0.5);
	}
	.books-section {
		background: #181b22;
	}
	.characters-section {
		background: #181b22;
	}
	.newsletter-section {
		background: #181b22;
	}

	.hero {
		min-height: 100vh;
		position: relative;
		display: flex;
		align-items: center;
		overflow: hidden;
		padding-top: 130px;
		padding-bottom: 60px;
		background: #181b22;
	}

	.hero-urban-bg {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse 80% 60% at 30% 50%, rgba(24, 20, 30, 0.7) 0%, transparent 60%),
			radial-gradient(ellipse 60% 80% at 70% 60%, rgba(10, 10, 24, 0.6) 0%, transparent 65%),
			linear-gradient(160deg, #141620 0%, #181b22 40%, #141620 100%);
		z-index: 0;
	}

	.hero-urban-bg::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image:
			repeating-linear-gradient(
				0deg,
				transparent,
				transparent 2px,
				rgba(255, 255, 255, 0.008) 2px,
				rgba(255, 255, 255, 0.008) 4px
			),
			repeating-linear-gradient(
				90deg,
				transparent,
				transparent 40px,
				rgba(255, 255, 255, 0.004) 40px,
				rgba(255, 255, 255, 0.004) 41px
			);
	}

	.hero-urban-bg::after {
		content: '';
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse 40% 30% at 20% 20%, rgba(255, 0, 255, 0.05) 0%, transparent 70%),
			radial-gradient(ellipse 30% 40% at 80% 70%, rgba(255, 0, 255, 0.05) 0%, transparent 70%);
	}

	.hero-grain {
		position: absolute;
		inset: 0;
		z-index: 1;
		background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='grain'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23grain)' opacity='0.06'/%3E%3C/svg%3E");
		background-size: 220px 220px;
		opacity: 0.5;
		pointer-events: none;
		mix-blend-mode: overlay;
	}

	.hero-split {
		position: relative;
		z-index: 2;
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 60px;
		align-items: flex-end;
	}

	.hero-image-col {
		position: relative;
		display: flex;
		justify-content: center;
	}

	/* ── CAROUSEL ── */
	.character-carousel {
		position: relative;
		width: 100%;
		display: flex;
		justify-content: center;
	}

	.carousel-slide {
		display: none;
		width: 100%;
	}

	.carousel-slide.active {
		display: block;
