---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import { getAllBlogPosts, getBlogPostBySlug } from '../../lib/sanity';

export async function getStaticPaths() {
  const posts = await getAllBlogPosts();
  return (posts || []).map((p: any) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const post = await getBlogPostBySlug(slug!);
if (!post) return Astro.redirect('/alleyway-gazette');

function renderBlock(block: any): string {
  if (block._type !== 'block') return '';
  const children = block.children || [];
  const inner = children
    .map((child: any) => {
      let text = (child.text || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
      if (child.marks?.includes('strong')) text = `<strong>${text}</strong>`;
      if (child.marks?.includes('em')) text = `<em>${text}</em>`;
      return text;
    })
    .join('');
  if (!inner.trim()) return '';
  switch (block.style) {
    case 'h2': return `<h2>${inner}</h2>`;
    case 'h3': return `<h3>${inner}</h3>`;
    case 'h4': return `<h4>${inner}</h4>`;
    case 'blockquote': return `<blockquote>${inner}</blockquote>`;
    default: return `<p>${inner}</p>`;
  }
}

function formatDate(dateStr: string) {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  }).toUpperCase();
}

const bodyBlocks: string[] = (post.body || [])
  .map((block: any) => renderBlock(block))
  .filter(Boolean);
---

<Layout
  title={post.seoTitle || `${post.title} — The Alleyway Gazette`}
  description={post.seoDescription || post.excerpt || ''}
>
  <Navigation />
  <main class="article-main">

    <header class="article-header">
      <div class="header-texture"></div>
      <div class="container article-header-inner">
        <div class="header-nav">
          <a href="/alleyway-gazette" class="back-link">&larr; The Alleyway Gazette</a>
          {post.category && (
            <span class="article-category">{post.category}</span>
          )}
        </div>
        <h1 class="article-title">{post.title}</h1>
        <div class="title-rule"></div>
        {post.excerpt && (
          <p class="article-deck">{post.excerpt}</p>
        )}
        {post.publishedAt && (
          <p class="article-dateline">{formatDate(post.publishedAt)} &mdash; THE ALLEYWAY GAZETTE</p>
        )}
      </div>
    </header>

    <div class="article-body-wrap">
      <div class="container">
        <div class="article-body">
          {bodyBlocks.map((html) => <Fragment set:html={html} />)}
        </div>
        <div class="article-footer">
          <div class="footer-rule"></div>
          <a href="/alleyway-gazette" class="back-btn">&larr; Back to The Alleyway Gazette</a>
        </div>
      </div>
    </div>

  </main>
  <Footer />
</Layout>

<style>
  .article-main {
    background: var(--charcoal);
    min-height: 100vh;
  }

  /* ── HEADER ── */
  .article-header {
    position: relative;
    padding: 140px 0 80px;
    background: #181b22;
    overflow: hidden;
  }

  .header-texture {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(255,0,255,0.08) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 30%, rgba(255,0,255,0.05) 0%, transparent 50%);
    pointer-events: none;
  }

  .article-header-inner {
    position: relative;
    max-width: 860px;
    margin: 0 auto;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }

  .back-link {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 0.85rem;
    letter-spacing: 2px;
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: #ff00ff;
  }

  .article-category {
    font-family: 'Oswald', 'Bebas Neue', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    padding: 3px 10px;
    color: #ff00ff;
    border: 1px solid #ff00ff;
    background: rgba(255,0,255,0.08);
  }

  .article-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    color: #ffffff;
    line-height: 0.95;
    letter-spacing: 3px;
    margin-bottom: 24px;
    text-shadow:
      3px 4px 0 rgba(255,0,255,0.25),
      0 0 40px rgba(255,0,255,0.1);
  }

  .title-rule {
    width: 80px;
    height: 3px;
    background: #ff00ff;
    margin-bottom: 24px;
    opacity: 0.7;
  }

  .article-deck {
    font-family: 'Inter', sans-serif;
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(255,255,255,0.65);
    line-height: 1.7;
    margin-bottom: 20px;
    font-style: italic;
    max-width: 720px;
  }

  .article-dateline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 3px;
    color: rgba(255,0,255,0.5);
  }

  /* ── BODY ── */
  .article-body-wrap {
    padding: 4rem 2rem 5rem;
  }

  .article-body-wrap .container {
    max-width: 860px;
    margin: 0 auto;
  }

  .article-body {
    font-family: 'Inter', sans-serif;
    font-size: 1.05rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.85;
  }

  .article-body :global(p) {
    margin-bottom: 1.6rem;
  }

  .article-body :global(h2) {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    color: #ffffff;
    letter-spacing: 2px;
    margin: 3rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255,0,255,0.2);
    text-shadow: 1px 2px 6px rgba(0,0,0,0.6);
  }

  .article-body :global(h3) {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem;
    color: #ffffff;
    letter-spacing: 1.5px;
    margin: 2.5rem 0 0.75rem;
  }

  .article-body :global(h4) {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #ffffff;
    margin: 2rem 0 0.5rem;
  }

  .article-body :global(strong) {
    color: #ffffff;
    font-weight: 700;
  }

  .article-body :global(em) {
    color: rgba(255,255,255,0.85);
    font-style: italic;
  }

  .article-body :global(blockquote) {
    border-left: 3px solid #ff00ff;
    padding: 0.75rem 1.5rem;
    margin: 2rem 0;
    background: rgba(255,0,255,0.05);
    color: rgba(255,255,255,0.6);
    font-style: italic;
    position: relative;
  }

  /* ── FOOTER ── */
  .article-footer {
    margin-top: 3rem;
  }

  .footer-rule {
    height: 1px;
    background: rgba(255,0,255,0.2);
    margin-bottom: 2rem;
  }

  .back-btn {
    display: inline-block;
    font-family: 'Oswald', 'Bebas Neue', sans-serif;
    font-size: 0.85rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,0,255,0.7);
    text-decoration: none;
    border: 1px solid rgba(255,0,255,0.3);
    padding: 10px 28px;
    transition: all 0.25s ease;
  }

  .back-btn:hover {
    color: #ff00ff;
    border-color: #ff00ff;
    box-shadow: 0 0 16px rgba(255,0,255,0.2);
  }

  @media (max-width: 768px) {
    .article-title { letter-spacing: 1px; }
    .article-body-wrap { padding: 2.5rem 1.5rem 4rem; }
  }
</style>
