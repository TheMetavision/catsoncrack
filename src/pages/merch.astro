---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { getAllProducts } from '../lib/sanity';

const products = await getAllProducts();

/* Stable per-design seed from the slug, so each card lands on a consistent
   colour across builds (no random reshuffle every deploy). */
function hashSeed(str) {
  let h = 0;
  for (let i = 0; i < String(str).length; i++) h = (h * 31 + String(str).charCodeAt(i)) | 0;
  return Math.abs(h);
}

/* Per-garment card image: show THIS garment's mockup in a colour picked by a
   hash of slug+type, so cards land across the full colourway range (no wall of
   pink) while staying stable across builds. */
function cardImageFor(p, variant) {
  const imgs = variant?.colourImages || [];
  if (imgs.length) {
    /* Only spread cards across the colourway range when the garment actually
       has multiple distinct colours (apparel). Colourless products — can glass,
       tumbler, socks (colour "") — carry several presentation shots (e.g. glass
       no-lid vs lid & straw), and the hash would split cards ~50/50 between them.
       For those, always use the primary (first) image so every card matches. */
    const distinctColours = [...new Set(imgs.map((i) => i.colour || ''))].filter(Boolean);
    const idx = distinctColours.length > 1
      ? hashSeed((p.slug || p.name || '') + '-' + (variant.productType || '')) % imgs.length
      : 0;
    return { url: imgs[idx].imageUrl || variant.printfulImageUrl || '', colour: imgs[idx].colour || '' };
  }
  return { url: variant?.printfulImageUrl || '', colour: '' };
}

/* Garment categories, in display order. Each tab shows every design available
   on that garment; empty categories are dropped automatically. */
const categoryOrder = [
  { key: 'tshirt', label: 'T-Shirts', types: ['tshirt'] },
  { key: 'hoodie', label: 'Hoodies', types: ['hoodie'] },
  { key: 'tank', label: 'Tanks', types: ['tank'] },
  { key: 'longsleeve', label: 'Long Sleeves', types: ['longsleeve'] },
  { key: 'tumbler', label: 'Tumblers', types: ['tumbler'] },
  { key: 'glass', label: 'Can Glasses', types: ['glass'] },
  { key: 'socks', label: 'Socks', types: ['socks'] },
];

const categories = categoryOrder.map((cat) => ({
  key: cat.key,
  label: cat.label,
  items: products.flatMap((p) =>
    (p.variants || [])
      .filter((v) => cat.types.includes(v.productType))
      .map((variant) => {
        const { url, colour } = cardImageFor(p, variant);
        const prices = (variant.sizePrices || []).map((s) => s.price).filter((n) => typeof n === 'number');
        const price = prices.length ? Math.min(...prices) : variant.basePrice;
        return {
          slug: p.slug, name: p.name, tagline: p.tagline || p.backstory,
          price, image: url, colour, type: variant.label, typeKey: variant.productType,
        };
      })
  ),
})).filter((cat) => cat.items.length > 0);

const defaultCat = categories[0]?.key || 'tshirt';
---

<Layout title="Merch - Cats On Crack" description="Shop official Cats On Crack merchandise — apparel, accessories, and collectibles featuring your favorite alley cats.">
  <Navigation />

  <main class="merch-main">

    <section class="hero-banner">
      <div class="hero-noise"></div>
      <div class="container hero-inner">
        <p class="hero-eyebrow">Official Drop — Season 01</p>
        <h1 class="hero-title">Street Gear</h1>
        <p class="hero-sub">Rep the alley.</p>
      </div>
    </section>

    <section class="section products-section">
      <div class="container">
        <div class="section-header">
          <div class="header-rule"></div>
          <h2 class="section-title">The Drop</h2>
          <div class="header-rule"></div>
        </div>

        {categories.length === 0 ? (
          <p class="empty-note">New gear dropping soon. Check back shortly.</p>
        ) : (
          <>
            <nav class="cat-tabs" aria-label="Product categories">
              {categories.map((cat) => (
                <button
                  class={`cat-tab ${cat.key === defaultCat ? 'active' : ''}`}
                  data-cat={cat.key}
                  aria-pressed={cat.key === defaultCat ? 'true' : 'false'}
                >
                  {cat.label}<span class="cat-count">{cat.items.length}</span>
                </button>
              ))}
            </nav>

            {categories.map((cat) => (
              <div class={`products-grid ${cat.key === defaultCat ? 'active' : ''}`} data-grid={cat.key}>
                {cat.items.map((item) => (
                  <a class="product-card" href={`/product/${item.slug}?type=${item.typeKey}`}>
                    <div class="card-worn-edge top-edge"></div>
                    <div class="card-worn-edge bottom-edge"></div>

                    <div class="product-thumb">
                      <div class="thumb-bg-noise"></div>
                      <img class="product-img" src={item.image} alt={`${item.name} ${item.type}`} loading="lazy" />
                    </div>

                    <div class="product-info">
                      <h3>{item.name}</h3>
                      {item.colour && <span class="product-colour">{item.colour}</span>}
                      <p class="product-desc">{item.tagline}</p>
                      <div class="product-footer">
                        <span class="product-price">{item.price != null ? `from £${item.price.toFixed(2)}` : ''}</span>
                        <span class="shop-btn">Shop</span>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            ))}
          </>
        )}
      </div>
    </section>

    <section class="early-access-section">
      <div class="ea-noise"></div>
      <div class="container">
        <div class="ea-box fade-in">
          <div class="ea-stamp-corner">EXCLUSIVE</div>
          <div class="ea-inner-border">
            <p class="ea-eyebrow">&#9670; Join the alley &#9670;</p>
            <h2 class="ea-title">Drop Alerts</h2>
            <div class="ea-divider"></div>
            <p class="ea-body">
              Subscribers hear about new drops, restocks, and subscriber-only colourways before anyone else.
            </p>
            <form class="ea-form" id="ea-form">
              <div class="ea-input-group">
                <input type="email" placeholder="Drop your email" required id="ea-email" />
                <button type="submit" class="ea-submit">
                  <span class="ea-btn-text">Sign Up</span>
                  <span class="ea-btn-arrow">&#8594;</span>
                </button>
              </div>
              <p class="ea-disclaimer">No spam. Unsubscribe anytime.</p>
            </form>
            <div class="ea-success" id="ea-success" style="display:none;">
              <p class="ea-success-msg">&#10003; You're on the list.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  .merch-main { background: #181b22; }

  /* ── HERO ── */
  .hero-banner { position: relative; padding: 150px 0 80px; background: #181b22; text-align: center; overflow: hidden; }
  .hero-noise { position: absolute; inset: 0; background:
      radial-gradient(ellipse at 30% 50%, rgba(255,0,255,0.12) 0%, transparent 60%),
      radial-gradient(ellipse at 70% 30%, rgba(255,0,255,0.06) 0%, transparent 50%); pointer-events: none; }
  .hero-inner { position: relative; }
  .hero-eyebrow { font-family: 'Bebas Neue', sans-serif; font-size: 0.85rem; letter-spacing: 5px; color: #ff00ff; text-transform: uppercase; margin-bottom: 12px; opacity: 0.9; }
  .hero-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(4rem, 10vw, 9rem); color: #fff; line-height: 0.9; letter-spacing: 4px; margin-bottom: 20px;
      text-shadow: 4px 4px 0 rgba(255,0,255,0.4), 8px 8px 0 rgba(255,0,255,0.15), 0 0 60px rgba(255,0,255,0.2); }
  .hero-sub { font-size: 1.1rem; color: rgba(255,255,255,0.5); letter-spacing: 2px; text-transform: uppercase; font-family: 'Bebas Neue', sans-serif; }

  /* ── PRODUCTS ── */
  .products-section { background: #181b22; padding: 100px 0; }
  .section-header { display: flex; align-items: center; gap: 24px; margin-bottom: 60px; }
  .header-rule { flex: 1; height: 1px; background: linear-gradient(90deg, transparent, rgba(255,0,255,0.4) 60%); }
  .header-rule:last-child { background: linear-gradient(270deg, transparent, rgba(255,0,255,0.4) 60%); }
  .section-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2rem, 4vw, 3.5rem); color: #fff; letter-spacing: 4px; white-space: nowrap; text-shadow: 0 0 30px rgba(255,0,255,0.3); }
  .empty-note { text-align: center; color: rgba(255,255,255,0.5); font-family: 'Bebas Neue', sans-serif; letter-spacing: 2px; }

  /* ── CATEGORY PILLS ── */
  .cat-tabs { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; margin-bottom: 48px; }
  .cat-tab { display: inline-flex; align-items: center; gap: 8px; padding: 9px 18px; background: #1a1d2e; border: 1px solid rgba(255,0,255,0.25); color: rgba(255,255,255,0.7); font-family: 'Bebas Neue', sans-serif; font-size: 0.95rem; letter-spacing: 2px; text-transform: uppercase; cursor: pointer; transition: all 0.25s ease; }
  .cat-tab:hover { border-color: #ff00ff; color: #fff; }
  .cat-tab.active { background: #ff00ff; border-color: #ff00ff; color: #fff; box-shadow: 0 0 18px rgba(255,0,255,0.35); }
  .cat-count { display: inline-flex; align-items: center; justify-content: center; min-width: 20px; height: 18px; padding: 0 5px; font-size: 0.7rem; background: rgba(0,0,0,0.25); color: inherit; }
  .cat-tab:not(.active) .cat-count { background: rgba(255,0,255,0.12); }

  .products-grid { display: none; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: 32px; animation: gridFade 0.35s ease; }
  .products-grid.active { display: grid; }
  @keyframes gridFade { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

  .product-card { position: relative; background: #1a1d2e; border: 1px solid rgba(255,0,255,0.15); overflow: visible; transition: transform 0.3s ease, box-shadow 0.3s ease; text-decoration: none; display: block; }
  .card-worn-edge { position: absolute; left: -2px; right: -2px; height: 4px; z-index: 2; background: #181b22;
    clip-path: polygon(0% 0%,3% 100%,6% 0%,9% 100%,12% 0%,15% 100%,18% 0%,21% 100%,24% 0%,27% 100%,30% 0%,33% 100%,36% 0%,39% 100%,42% 0%,45% 100%,48% 0%,51% 100%,54% 0%,57% 100%,60% 0%,63% 100%,66% 0%,69% 100%,72% 0%,75% 100%,78% 0%,81% 100%,84% 0%,87% 100%,90% 0%,93% 100%,96% 0%,100% 100%,100% 0%); }
  .top-edge { top: -2px; }
  .bottom-edge { bottom: -2px; transform: rotate(180deg); }
  .product-card:hover { transform: translateY(-8px) rotate(-0.3deg); box-shadow: 0 20px 50px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,0,255,0.3), 0 0 30px rgba(255,0,255,0.12); }

  .product-thumb { position: relative; aspect-ratio: 1; overflow: hidden; background: #252838; }
  .thumb-bg-noise { position: absolute; inset: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 300 300' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.08'/%3E%3C/svg%3E"); background-size: 200px 200px; pointer-events: none; }
  .product-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }

  .product-info { padding: 20px 22px 22px; border-top: 1px solid rgba(255,0,255,0.1); }
  .product-info h3 { font-family: 'Bebas Neue', sans-serif; font-size: 1.4rem; color: #fff; letter-spacing: 1px; margin-bottom: 6px; }
  .product-colour { display: block; font-size: 0.68rem; letter-spacing: 1.5px; text-transform: uppercase; color: rgba(255,0,255,0.55); margin-bottom: 8px; }
  .product-desc { font-size: 0.82rem; color: rgba(255,255,255,0.4); margin-bottom: 16px; line-height: 1.5; min-height: 2.4em; }
  .product-footer { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .product-price { font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; color: #fff; letter-spacing: 1px; }
  .shop-btn { font-family: 'Bebas Neue', sans-serif; font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase; color: #ff00ff; border: 1px solid rgba(255,0,255,0.4); padding: 6px 16px; transition: all 0.25s ease; }
  .product-card:hover .shop-btn { background: rgba(255,0,255,0.12); border-color: #ff00ff; box-shadow: 0 0 12px rgba(255,0,255,0.2); }

  /* ── EARLY ACCESS ── */
  .early-access-section { position: relative; padding: 100px 0; background: #181b22; overflow: hidden; }
  .ea-noise { position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 0%, rgba(255,0,255,0.18) 0%, transparent 55%), radial-gradient(ellipse at 80% 100%, rgba(255,0,255,0.08) 0%, transparent 50%); pointer-events: none; }
  .ea-box { position: relative; max-width: 760px; margin: 0 auto; background: #1f2233; border: 1px solid rgba(255,0,255,0.3); overflow: hidden; }
  .ea-stamp-corner { position: absolute; top: 0; right: 0; background: #ff00ff; color: #fff; font-family: 'Bebas Neue', sans-serif; font-size: 0.7rem; letter-spacing: 3px; padding: 8px 20px; text-transform: uppercase; }
  .ea-inner-border { border: 1px solid rgba(255,0,255,0.08); margin: 12px; padding: 52px 60px; text-align: center; position: relative; }
  .ea-eyebrow { font-family: 'Bebas Neue', sans-serif; font-size: 0.75rem; letter-spacing: 4px; color: #ff00ff; text-transform: uppercase; margin-bottom: 20px; opacity: 0.9; }
  .ea-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.5rem, 6vw, 5rem); color: #fff; line-height: 0.95; letter-spacing: 3px; margin-bottom: 24px; text-shadow: 3px 3px 0 rgba(255,0,255,0.3), 0 0 40px rgba(255,0,255,0.15); }
  .ea-divider { width: 60px; height: 3px; background: #ff00ff; margin: 0 auto 24px; }
  .ea-body { font-size: 0.95rem; color: rgba(255,255,255,0.55); line-height: 1.8; max-width: 520px; margin: 0 auto 28px; }
  .ea-form { max-width: 520px; margin: 0 auto; }
  .ea-input-group { display: flex; border: 1px solid rgba(255,0,255,0.5); background: rgba(0,0,0,0.4); transition: border-color 0.3s ease, box-shadow 0.3s ease; }
  .ea-input-group:focus-within { border-color: #ff00ff; box-shadow: 0 0 0 3px rgba(255,0,255,0.15); }
  .ea-input-group input { flex: 1; padding: 16px 20px; background: transparent; border: none; color: #fff; font-size: 0.9rem; outline: none; }
  .ea-input-group input::placeholder { color: rgba(255,255,255,0.3); }
  .ea-submit { display: flex; align-items: center; gap: 8px; padding: 16px 28px; background: #ff00ff; color: #fff; font-family: 'Bebas Neue', sans-serif; font-size: 0.85rem; letter-spacing: 2px; text-transform: uppercase; border: none; cursor: pointer; transition: all 0.3s ease; white-space: nowrap; }
  .ea-submit:hover { background: #cc00cc; box-shadow: 0 0 20px rgba(255,0,255,0.3); }
  .ea-btn-arrow { font-size: 1rem; transition: transform 0.2s ease; }
  .ea-submit:hover .ea-btn-arrow { transform: translateX(3px); }
  .ea-disclaimer { font-size: 0.72rem; color: rgba(255,255,255,0.25); margin-top: 12px; line-height: 1.5; }
  .ea-success-msg { font-family: 'Bebas Neue', sans-serif; font-size: 1rem; letter-spacing: 2px; color: #fff; padding: 20px; border: 1px solid rgba(255,0,255,0.3); background: rgba(255,0,255,0.06); }

  @media (max-width: 768px) {
    .products-grid { grid-template-columns: 1fr; }
    .ea-inner-border { padding: 36px 24px; }
    .ea-input-group { flex-direction: column; }
    .ea-submit { justify-content: center; }
  }
</style>

<script>
  /* Category tab switching */
  const tabs = document.querySelectorAll('.cat-tab');
  const grids = document.querySelectorAll('.products-grid[data-grid]');
  tabs.forEach((tab) => tab.addEventListener('click', () => {
    const cat = tab.getAttribute('data-cat');
    if (!cat) return;
    tabs.forEach((t) => { t.classList.remove('active'); t.setAttribute('aria-pressed', 'false'); });
    tab.classList.add('active');
    tab.setAttribute('aria-pressed', 'true');
    grids.forEach((g) => g.classList.toggle('active', g.getAttribute('data-grid') === cat));
  }));

  /* Newsletter signup — posts to a Netlify function so no API token lives in
     the browser. Create netlify/functions/subscribe (reuse your existing
     newsletter pattern) that reads MAILERLITE_TOKEN from env and adds the
     subscriber to the COC group. */
  const form = document.getElementById('ea-form');
  const success = document.getElementById('ea-success');
  if (form && success) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (document.getElementById('ea-email') as HTMLInputElement)?.value;
      if (!email) return;
      const btn = form.querySelector('.ea-submit') as HTMLButtonElement | null;
      const btnText = form.querySelector('.ea-btn-text');
      if (btnText) btnText.textContent = 'Signing up...';
      if (btn) btn.disabled = true;
      try {
        await fetch('/.netlify/functions/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        form.style.display = 'none';
        success.style.display = 'block';
      } catch (_) {
        if (btnText) btnText.textContent = 'Sign Up';
        if (btn) btn.disabled = false;
      }
    });
  }
</script>
