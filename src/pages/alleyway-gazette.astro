---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { getAllBlogPosts } from '../lib/sanity';

const allPosts = await getAllBlogPosts();
const posts = allPosts || [];
const featuredPost = posts[0] || null;
const gridPosts = posts.length > 1 ? posts.slice(1) : posts;

function formatDateline(dateStr: string) {
  if (!dateStr) return 'ISSUE NO. 1';
  const d = new Date(dateStr);
  const month = d.toLocaleDateString('en-US', { month: 'long' }).toUpperCase();
  const year = d.getFullYear();
  return `${month} ${year}`;
}

function formatDate(dateStr: string) {
  if (!dateStr) return '';
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).toUpperCase();
}

// Category → thumbnail variant
const thumbVariants: Record<string, string> = {
  'Action': 'story-thumb-action',
  'Profile': 'story-thumb-profile',
  'Character Spotlight': 'story-thumb-profile',
  'Characters': 'story-thumb-profile',
  'Behind the Scenes': 'story-thumb-bts',
  'Guide': 'story-thumb-guide',
  'Legends': 'story-thumb-legends',
  'Review': 'story-thumb-review',
};
function getThumbVariant(cat: string) {
  return thumbVariants[cat] || 'story-thumb-action';
}
---

<Layout title="The Alleyway Gazette - Cats On Crack" description="Read the latest stories, news, and tales from the streets. The Alleyway Gazette brings you all the gritty details from the Cats On Crack universe.">
  <Navigation />
  <main class="gazette-main">

    <section class="masthead">
      <div class="masthead-texture"></div>
      <div class="container masthead-inner">
        <p class="masthead-eyebrow">EST. 2025 &nbsp;·&nbsp; VOLUME I</p>
        <h1 class="masthead-title">The Alleyway Gazette</h1>
        <p class="masthead-tagline">Tales from the Streets — Unfiltered &amp; Uncensored</p>
      </div>
    </section>

    {featuredPost && (
      <section class="featured-hero">
        <div class="featured-hero-texture"></div>
        <div class="container">
          <div class="featured-hero-inner fade-in">
            <div class="featured-dateline">
              <span class="featured-badge">&#9733; Featured Story</span>
              <span class="dateline-text">ISSUE NO. 1 &mdash; {formatDateline(featuredPost.publishedAt)} &mdash; EAST SIDE EDITION</span>
            </div>
            <h2 class="featured-headline">{featuredPost.title}</h2>
            <div class="featured-deck-rule"></div>
            <p class="featured-deck">{featuredPost.excerpt}</p>
            <a href={`/alleyway-gazette/${featuredPost.slug}`} class="featured-read-more">Read Full Story &rarr;</a>
          </div>
        </div>
      </section>
    )}

    <div class="grunge-divider">
      <svg viewBox="0 0 1400 40" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,20 Q50,8 100,18 T200,15 T300,22 T400,12 T500,20 T600,16 T700,22 T800,14 T900,20 T1000,17 T1100,23 T1200,15 T1300,21 T1400,18 L1400,40 L0,40 Z" fill="#181b22" opacity="0.9"/>
        <path d="M0,28 Q70,16 150,26 T300,22 T450,28 T600,20 T750,27 T900,22 T1050,28 T1200,21 T1400,26 L1400,40 L0,40 Z" fill="#181b22" opacity="0.6"/>
      </svg>
    </div>

    <section class="section chronicles-section">
      <div class="container">
        <div class="section-header">
          <div class="section-rule"></div>
          <h2 class="section-title">Latest Chronicles</h2>
          <div class="section-rule"></div>
        </div>
        <div class="stories-grid">
          {gridPosts.map((post: any) => (
            <article class="story-card fade-in">
              <div class={`story-card-thumb ${getThumbVariant(post.category)}`}>
                <div class="thumb-texture"></div>
                <svg class="thumb-icon" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
                  <rect x="14" y="8" width="36" height="48" rx="3" fill="none" stroke="currentColor" stroke-width="2.5"/>
                  <line x1="22" y1="22" x2="42" y2="22" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                  <line x1="22" y1="30" x2="42" y2="30" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                  <line x1="22" y1="38" x2="34" y2="38" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                </svg>
                <span class="thumb-label">{post.category || 'Stories'}</span>
              </div>
              <div class="story-card-content">
                <span class="story-category cat-default">{post.category || 'Stories'}</span>
                <h3>{post.title}</h3>
                <p>{post.excerpt}</p>
                <a href={`/alleyway-gazette/${post.slug}`} class="story-link">Continue Reading &rarr;</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <div class="grunge-divider inverted">
      <svg viewBox="0 0 1400 40" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,20 Q50,8 100,18 T200,15 T300,22 T400,12 T500,20 T600,16 T700,22 T800,14 T900,20 T1000,17 T1100,23 T1200,15 T1300,21 T1400,18 L1400,0 L0,0 Z" fill="#181b22" opacity="0.8"/>
      </svg>
    </div>

    <section class="section newsletter-signup">
      <div class="container">
        <div class="newsletter-box fade-in">
          <p class="newsletter-eyebrow">&#9135; Subscribe &#9135;</p>
          <h2>Never Miss an Issue</h2>
          <p>Get the latest stories, character updates, and exclusive content delivered straight to your inbox every week.</p>
          <form class="inline-newsletter-form" id="gazetteNewsletterForm">
            <input type="email" name="email" placeholder="Your email address" required />
            <button type="submit" class="cta-button" id="gazetteBtn">Subscribe Now</button>
          </form>
          <p id="gazetteMessage" style="display:none; margin-top:16px; font-weight:700; color:#ff00ff; font-size:1rem;"></p>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Oswald:wght@700&display=swap');

  .gazette-main {
    background: var(--charcoal);
  }

  /* ── MASTHEAD ── */
  .masthead {
    position: relative;
    padding: 150px 0 80px;
    background: #181b22;
    text-align: center;
    overflow: hidden;
  }

  .masthead-texture {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 50%, rgba(255,0,255,0.1) 0%, transparent 60%),
      radial-gradient(ellipse at 70% 30%, rgba(255,0,255,0.05) 0%, transparent 50%);
    pointer-events: none;
  }

  .masthead-inner {
    position: relative;
  }

  .masthead-eyebrow {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 0.85rem;
    letter-spacing: 5px;
    color: #ff00ff;
    text-transform: uppercase;
    margin-bottom: 12px;
    opacity: 0.9;
  }

  .masthead-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 10vw, 9rem);
    color: #ffffff;
    line-height: 0.9;
    letter-spacing: 4px;
    margin-bottom: 20px;
    text-shadow:
      4px 4px 0 rgba(255,0,255,0.4),
      8px 8px 0 rgba(255,0,255,0.15),
      0 0 60px rgba(255,0,255,0.2);
  }

  .masthead-tagline {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.5);
    letter-spacing: 2px;
    text-transform: uppercase;
    font-family: 'Bebas Neue', sans-serif;
  }

  /* ── FEATURED HERO ── */
  .featured-hero {
    position: relative;
    padding: 80px 0;
    background: var(--bg-darker);
    overflow: hidden;
  }

  .featured-hero-texture {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.06'/%3E%3C/svg%3E");
    background-size: 300px 300px;
    opacity: 0.7;
    pointer-events: none;
  }

  .featured-hero-inner {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
    border: 1px solid rgba(255,0,255,0.25);
    padding: 60px 80px;
    background: rgba(24,27,34,0.8);
  }

  .featured-hero-inner::before {
    content: '';
    position: absolute;
    inset: 6px;
    border: 1px solid rgba(255,0,255,0.1);
    pointer-events: none;
  }

  .featured-dateline {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: 30px;
  }

  .featured-badge {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #ffffff;
    background: #ff00ff;
    padding: 5px 14px;
    font-weight: 700;
  }

  .dateline-text {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 2.5px;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
  }

  .featured-headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3rem, 8vw, 6rem);
    color: #ffffff;
    line-height: 0.95;
    letter-spacing: 2px;
    margin-bottom: 30px;
    text-shadow: 3px 6px 12px rgba(0,0,0,0.8), 0 0 60px rgba(255,0,255,0.12);
  }

  .featured-deck-rule {
    width: 80px;
    height: 3px;
    background: #ff00ff;
    margin: 0 auto 24px;
    opacity: 0.7;
  }

  .featured-deck {
    font-family: 'Inter', sans-serif;
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(255,255,255,0.7);
    line-height: 1.7;
    margin-bottom: 36px;
    font-style: italic;
  }

  .featured-read-more {
    display: inline-block;
    font-family: 'Oswald', 'Bebas Neue', sans-serif;
    font-size: 1rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #ffffff;
    background: #ff00ff;
    padding: 14px 40px;
    border: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(255,0,255,0.35);
    text-decoration: none;
  }

  .featured-read-more:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(255,0,255,0.5);
  }

  /* ── GRUNGE DIVIDERS ── */
  .grunge-divider {
    display: block;
    line-height: 0;
    margin: 0;
  }

  .grunge-divider svg {
    display: block;
    width: 100%;
    height: 40px;
  }

  /* ── CHRONICLES SECTION ── */
  .chronicles-section {
    background: var(--charcoal);
    position: relative;
  }

  .chronicles-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.68' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.05'/%3E%3C/svg%3E");
    background-size: 256px 256px;
    pointer-events: none;
    opacity: 0.6;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 60px;
  }

  .section-rule {
    flex: 1;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(255,0,255,0.4) 60%);
  }

  .section-rule:last-child {
    background: linear-gradient(270deg, transparent, rgba(255,0,255,0.4) 60%);
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    color: #ffffff;
    white-space: nowrap;
    letter-spacing: 2px;
    text-shadow: 1px 2px 6px rgba(0,0,0,0.6);
  }

  .stories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 30px;
    position: relative;
  }

  .story-card {
    background: var(--bg-card);
    border: 1px solid rgba(255,0,255,0.15);
    overflow: hidden;
    transition: all 0.3s ease;
    position: relative;
  }

  .story-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 300 300' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    background-size: 200px 200px;
    pointer-events: none;
    z-index: 0;
    opacity: 0.8;
  }

  .story-card:hover {
    transform: translateY(-6px);
    border-color: rgba(255,0,255,0.4);
    box-shadow: 0 12px 40px rgba(0,0,0,0.6), 0 0 20px rgba(255,0,255,0.08);
  }

  /* ── BRANDED THUMBNAILS ── */
  .story-card-thumb {
    aspect-ratio: 16/9;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    gap: 12px;
  }

  .thumb-texture {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.12'/%3E%3C/svg%3E");
    background-size: 128px 128px;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  .thumb-icon {
    width: 52px;
    height: 52px;
    position: relative;
    z-index: 1;
    opacity: 0.85;
  }

  .thumb-label {
    font-family: 'Oswald', 'Bebas Neue', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    position: relative;
    z-index: 1;
    opacity: 0.7;
  }

  .story-thumb-action { background: linear-gradient(135deg, #1f2030 0%, #181b22 60%, #1a1d2a 100%); color: #ff00ff; }
  .story-thumb-profile { background: linear-gradient(135deg, #1a1d2e 0%, #181b22 60%, #1f2230 100%); color: #ff00ff; }
  .story-thumb-bts { background: linear-gradient(135deg, #1e2030 0%, #181b22 60%, #1a1d2a 100%); color: #ff00ff; }
  .story-thumb-guide { background: linear-gradient(135deg, #1f2030 0%, #181b22 60%, #1a1c28 100%); color: #ff00ff; }
  .story-thumb-legends { background: linear-gradient(135deg, #20152e 0%, #181b22 60%, #1c1430 100%); color: #ff00ff; }
  .story-thumb-review { background: linear-gradient(135deg, #141e2e 0%, #181b22 60%, #121a28 100%); color: #ff00ff; }

  .story-card:hover .thumb-icon {
    opacity: 1;
    transform: scale(1.08);
    transition: all 0.3s ease;
  }

  /* ── CARD CONTENT ── */
  .story-card-content {
    padding: 22px 24px 26px;
    position: relative;
    z-index: 1;
  }

  .story-category {
    display: inline-block;
    font-family: 'Oswald', 'Bebas Neue', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    padding: 3px 10px;
    margin-bottom: 12px;
    border-width: 1px;
    border-style: solid;
  }

  .cat-default {
    color: #ff00ff;
    border-color: #ff00ff;
    background: rgba(255,0,255,0.08);
  }

  .story-card h3 {
    font-family: 'Oswald', 'Bebas Neue', sans-serif;
    font-size: 1.35rem;
    color: #ffffff;
    margin-bottom: 10px;
    line-height: 1.25;
    letter-spacing: 0.5px;
  }

  .story-card p {
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 14px;
  }

  .story-link {
    font-family: 'Oswald', 'Bebas Neue', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,0,255,0.7);
    transition: all 0.25s ease;
    text-decoration: none;
  }

  .story-link:hover {
    color: #ff00ff;
    text-shadow: 0 0 8px rgba(255,0,255,0.4);
  }

  /* ── NEWSLETTER ── */
  .newsletter-signup {
    background: var(--bg-darker);
  }

  .newsletter-box {
    border: 1px solid rgba(255,0,255,0.25);
    padding: 60px 80px;
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    background: var(--bg-card);
  }

  .newsletter-box::before {
    content: '';
    position: absolute;
    inset: 6px;
    border: 1px solid rgba(255,0,255,0.08);
    pointer-events: none;
  }

  .newsletter-eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 4px;
    color: rgba(255,0,255,0.7);
    text-transform: uppercase;
    margin-bottom: 14px;
  }

  .newsletter-box h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem);
    color: #ffffff;
    margin-bottom: 16px;
    letter-spacing: 2px;
  }

  .newsletter-box p {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 28px;
    line-height: 1.8;
  }

  .inline-newsletter-form {
    display: flex;
    gap: 12px;
    max-width: 520px;
    margin: 0 auto;
    flex-wrap: wrap;
    justify-content: center;
  }

  .inline-newsletter-form input {
    flex: 1;
    min-width: 220px;
    padding: 13px 18px;
    background: var(--bg-darker);
    border: 1px solid rgba(255,0,255,0.3);
    color: #ffffff;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    transition: all 0.3s ease;
  }

  .inline-newsletter-form input::placeholder {
    color: rgba(255,255,255,0.3);
  }

  .inline-newsletter-form input:focus {
    outline: none;
    border-color: #ff00ff;
    box-shadow: 0 0 0 2px rgba(255,0,255,0.12);
  }

  .cta-button {
    padding: 13px 32px;
    background: #ff00ff;
    color: #ffffff;
    font-family: 'Oswald', 'Bebas Neue', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(255,0,255,0.3);
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(255,0,255,0.45);
  }

  @media (max-width: 968px) {
    .featured-hero-inner { padding: 40px 40px; }
  }

  @media (max-width: 768px) {
    .stories-grid { grid-template-columns: 1fr; }
    .featured-hero-inner { padding: 32px 24px; }
    .section-title { font-size: 2rem; }
    .newsletter-box { padding: 40px 28px; }
    .inline-newsletter-form { flex-direction: column; }
    .inline-newsletter-form input { width: 100%; }
  }
</style>

<script>
  const gazetteForm = document.getElementById('gazetteNewsletterForm') as HTMLFormElement | null;
  const gazetteMsg = document.getElementById('gazetteMessage');
  const gazetteBtn = document.getElementById('gazetteBtn') as HTMLButtonElement | null;

  gazetteForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (gazetteForm.querySelector('input[name="email"]') as HTMLInputElement)?.value;
    if (!email || !gazetteBtn) return;
    gazetteBtn.textContent = 'Subscribing...';
    gazetteBtn.disabled = true;
    try {
      const response = await fetch('https://connect.mailerlite.com/api/subscribers', {
        method: 'POST',
