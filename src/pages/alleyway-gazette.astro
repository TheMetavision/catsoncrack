---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="The Alleyway Gazette - Cats On Crack" description="Read the latest stories, news, and tales from the streets. The Alleyway Gazette brings you all the gritty details from the Cats On Crack universe.">
	<Navigation />

	<main class="gazette-main">

		<section class="masthead">
			<div class="masthead-texture"></div>
			<div class="container masthead-inner">
				<p class="masthead-eyebrow">EST. 2025 &nbsp;·&nbsp; VOLUME I</p>
				<h1 class="masthead-title">The Alleyway Gazette</h1>
				<p class="masthead-tagline">Tales from the Streets — Unfiltered &amp; Uncensored</p>
			</div>
		</section>

		<section class="featured-hero">
			<div class="featured-hero-texture"></div>
			<div class="container">
				<div class="featured-hero-inner fade-in">
					<div class="featured-dateline">
						<span class="featured-badge">&#9733; Featured Story</span>
						<span class="dateline-text">ISSUE NO. 1 &mdash; MARCH 2026 &mdash; EAST SIDE EDITION</span>
					</div>
					<h2 class="featured-headline">The Great<br/>Pipe Heist<br/>of '25</h2>
					<div class="featured-deck-rule"></div>
					<p class="featured-deck">
						When word spread about a warehouse full of glowing pipes on the east side, every crew in the city wanted a piece. But only one gang had the guts to pull off the impossible heist.
					</p>
					<div class="featured-body-columns">
						<p>From rooftop chases to underground tunnels, from double-crosses to last-minute saves, this tale has it all. Read about Whiskers' master plan, Shadow's stealth moves, and how everything almost fell apart when Scruffy got distracted by a fishmonger's cart.</p>
						<p>This is the story of how the Cats On Crack crew became legends in a single night — and why they're still running from the consequences six months later.</p>
					</div>
					<a href="#" class="featured-read-more">Read Full Story &rarr;</a>
				</div>
			</div>
		</section>

		<div class="grunge-divider">
			<svg viewBox="0 0 1400 40" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M0,20 Q50,8 100,18 T200,15 T300,22 T400,12 T500,20 T600,16 T700,22 T800,14 T900,20 T1000,17 T1100,23 T1200,15 T1300,21 T1400,18 L1400,40 L0,40 Z" fill="#181b22" opacity="0.9"/>
				<path d="M0,28 Q70,16 150,26 T300,22 T450,28 T600,20 T750,27 T900,22 T1050,28 T1200,21 T1400,26 L1400,40 L0,40 Z" fill="#181b22" opacity="0.6"/>
			</svg>
		</div>

		<section class="section chronicles-section">
			<div class="container">
				<div class="section-header">
					<div class="section-rule"></div>
					<h2 class="section-title">Latest Chronicles</h2>
					<div class="section-rule"></div>
				</div>

				<div class="stories-grid">

					<article class="story-card fade-in">
						<div class="story-card-thumb story-thumb-action">
							<div class="thumb-texture"></div>
							<svg class="thumb-icon" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
								<path d="M32 8 L38 26 H56 L42 37 L48 56 L32 44 L16 56 L22 37 L8 26 H26 Z" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/>
								<circle cx="32" cy="32" r="6" fill="currentColor" opacity="0.4"/>
							</svg>
							<span class="thumb-label">Action</span>
						</div>
						<div class="story-card-content">
							<span class="story-category cat-action">Action</span>
							<h3>Showdown at Midnight Alley</h3>
							<p>When rival gangs clash over territory, only the toughest survive. A firsthand account of the legendary face-off that changed the power dynamics of the streets forever.</p>
							<a href="#" class="story-link">Continue Reading &rarr;</a>
						</div>
					</article>

					<article class="story-card fade-in">
						<div class="story-card-thumb story-thumb-profile">
							<div class="thumb-texture"></div>
							<svg class="thumb-icon" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
								<circle cx="32" cy="22" r="11" fill="none" stroke="currentColor" stroke-width="2.5"/>
								<path d="M10 54 C10 40 54 40 54 54" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
								<circle cx="32" cy="22" r="4" fill="currentColor" opacity="0.4"/>
							</svg>
							<span class="thumb-label">Profile</span>
						</div>
						<div class="story-card-content">
							<span class="story-category cat-profile">Profile</span>
							<h3>Character Spotlight: Whiskers McScruff</h3>
							<p>From street orphan to gang leader — discover the untold story of how Whiskers rose through the ranks and became the mastermind behind the crew's biggest scores.</p>
							<a href="#" class="story-link">Continue Reading &rarr;</a>
						</div>
					</article>

					<article class="story-card fade-in">
						<div class="story-card-thumb story-thumb-bts">
							<div class="thumb-texture"></div>
							<svg class="thumb-icon" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
								<rect x="8" y="18" width="48" height="30" rx="3" fill="none" stroke="currentColor" stroke-width="2.5"/>
								<circle cx="32" cy="33" r="9" fill="none" stroke="currentColor" stroke-width="2.5"/>
								<circle cx="32" cy="33" r="3.5" fill="currentColor" opacity="0.5"/>
								<path d="M20 18 L24 12 H40 L44 18" fill="none" stroke="currentColor" stroke-width="2.5"/>
							</svg>
							<span class="thumb-label">Behind the Scenes</span>
						</div>
						<div class="story-card-content">
							<span class="story-category cat-bts">Behind the Scenes</span>
							<h3>Creating the Chaos: Animation Insights</h3>
							<p>Go behind the scenes of the animated series. Learn how the creative team brings the gritty world of alley cats to life, frame by frame.</p>
							<a href="#" class="story-link">Continue Reading &rarr;</a>
						</div>
					</article>

					<article class="story-card fade-in">
						<div class="story-card-thumb story-thumb-guide">
							<div class="thumb-texture"></div>
							<svg class="thumb-icon" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
								<rect x="14" y="8" width="36" height="48" rx="3" fill="none" stroke="currentColor" stroke-width="2.5"/>
								<line x1="22" y1="22" x2="42" y2="22" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
								<line x1="22" y1="30" x2="42" y2="30" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
								<line x1="22" y1="38" x2="34" y2="38" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
							</svg>
							<span class="thumb-label">Guide</span>
						</div>
						<div class="story-card-content">
							<span class="story-category cat-guide">Guide</span>
							<h3>The Unwritten Rules of Alley Life</h3>
							<p>Every street cat knows the code. Break it, and you're done. Here's your guide to surviving in the concrete jungle where only the smartest thrive.</p>
							<a href="#" class="story-link">Continue Reading &rarr;</a>
						</div>
					</article>

					<article class="story-card fade-in">
						<div class="story-card-thumb story-thumb-legends">
							<div class="thumb-texture"></div>
							<svg class="thumb-icon" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
								<path d="M32 10 Q36 22 48 22 Q38 30 42 44 Q32 36 22 44 Q26 30 16 22 Q28 22 32 10 Z" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/>
								<path d="M32 18 Q34 24 40 24 Q36 28 38 36 Q32 32 26 36 Q28 28 24 24 Q30 24 32 18 Z" fill="currentColor" opacity="0.3"/>
							</svg>
							<span class="thumb-label">Legends</span>
						</div>
						<div class="story-card-content">
							<span class="story-category cat-legends">Legends</span>
							<h3>Urban Myths: The Ghost Cat of 5th Street</h3>
							<p>Some say it's just a legend. Others swear they've seen it — a phantom feline that appears before major events. Is it real, or just another tall tale?</p>
							<a href="#" class="story-link">Continue Reading &rarr;</a>
						</div>
					</article>

					<article class="story-card fade-in">
						<div class="story-card-thumb story-thumb-review">
							<div class="thumb-texture"></div>
							<svg class="thumb-icon" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
								<path d="M12 12 H52 V44 H32 L20 56 V44 H12 Z" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/>
								<line x1="22" y1="24" x2="42" y2="24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
								<line x1="22" y1="32" x2="36" y2="32" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
							</svg>
							<span class="thumb-label">Review</span>
						</div>
						<div class="story-card-content">
							<span class="story-category cat-review">Review</span>
							<h3>Book Review: "Night of Nine Lives"</h3>
							<p>The latest installment in the Cats On Crack series delivers non-stop action, dark humor, and plot twists that'll leave you clawing for more.</p>
							<a href="#" class="story-link">Continue Reading &rarr;</a>
						</div>
					</article>

				</div>
			</div>
		</section>

		<div class="grunge-divider inverted">
			<svg viewBox="0 0 1400 40" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M0,20 Q50,8 100,18 T200,15 T300,22 T400,12 T500,20 T600,16 T700,22 T800,14 T900,20 T1000,17 T1100,23 T1200,15 T1300,21 T1400,18 L1400,0 L0,0 Z" fill="#181b22" opacity="0.8"/>
			</svg>
		</div>

		<section class="section newsletter-signup">
			<div class="container">
				<div class="newsletter-box fade-in">
					<p class="newsletter-eyebrow">&#9135; Subscribe &#9135;</p>
					<h2>Never Miss an Issue</h2>
					<p>Get the latest stories, character updates, and exclusive content delivered straight to your inbox every week.</p>
					<form class="inline-newsletter-form">
						<input type="email" placeholder="Your email address" required />
						<button type="submit" class="cta-button">Subscribe Now</button>
					</form>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<style>
	@import url('https://fonts.googleapis.com/css2?family=Oswald:wght@700&display=swap');

	.gazette-main {
		background: var(--charcoal);
	}

	/* ── MASTHEAD ── */
	.masthead {
		position: relative;
		padding: 150px 0 80px;
		background: #181b22;
		text-align: center;
		overflow: hidden;
	}

	.masthead-texture {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse at 30% 50%, rgba(255,0,255,0.1) 0%, transparent 60%),
			radial-gradient(ellipse at 70% 30%, rgba(255,0,255,0.05) 0%, transparent 50%);
		pointer-events: none;
	}

	.masthead-inner {
		position: relative;
	}

	.masthead-eyebrow {
		font-family: 'Bebas Neue', sans-serif;
		font-size: 0.85rem;
		letter-spacing: 5px;
		color: #ff00ff;
		text-transform: uppercase;
		margin-bottom: 12px;
		opacity: 0.9;
	}

	.masthead-title {
		font-family: 'Bebas Neue', sans-serif;
		font-size: clamp(2.5rem, 10vw, 9rem);
		color: #ffffff;
		line-height: 0.9;
		letter-spacing: 4px;
		margin-bottom: 20px;
		text-shadow:
			4px 4px 0 rgba(255,0,255,0.4),
			8px 8px 0 rgba(255,0,255,0.15),
			0 0 60px rgba(255,0,255,0.2);
	}

	.masthead-tagline {
		font-size: 1.1rem;
		color: rgba(255,255,255,0.5);
		letter-spacing: 2px;
		text-transform: uppercase;
		font-family: 'Bebas Neue', sans-serif;
	}

	/* ── FEATURED HERO ── */
	.featured-hero {
		position: relative;
		padding: 80px 0;
		background: var(--bg-darker);
		overflow: hidden;
	}

	.featured-hero-texture {
		position: absolute;
		inset: 0;
		background-image:
			url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.06'/%3E%3C/svg%3E");
		background-size: 300px 300px;
		opacity: 0.7;
		pointer-events: none;
	}

	.featured-hero-inner {
		position: relative;
		max-width: 900px;
		margin: 0 auto;
		text-align: center;
		border: 1px solid rgba(255,0,255,0.25);
		padding: 60px 80px;
		background: rgba(24,27,34,0.8);
	}

	.featured-hero-inner::before {
		content: '';
		position: absolute;
		inset: 6px;
		border: 1px solid rgba(255,0,255,0.1);
		pointer-events: none;
	}

	.featured-dateline {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 20px;
		flex-wrap: wrap;
		margin-bottom: 30px;
	}

	.featured-badge {
		font-family: 'Inter', sans-serif;
		font-size: 0.75rem;
		letter-spacing: 2px;
		text-transform: uppercase;
		color: #ffffff;
		background: #ff00ff;
		padding: 5px 14px;
		font-weight: 700;
	}

	.dateline-text {
		font-family: 'Inter', sans-serif;
		font-size: 0.72rem;
		letter-spacing: 2.5px;
		color: rgba(255,255,255,0.5);
		text-transform: uppercase;
	}

	.featured-headline {
		font-family: 'Bebas Neue', sans-serif;
		font-size: clamp(3.5rem, 8vw, 7rem);
		color: #ffffff;
		line-height: 0.95;
		letter-spacing: 2px;
		margin-bottom: 30px;
		text-shadow:
			3px 6px 12px rgba(0,0,0,0.8),
			0 0 60px rgba(255,0,255,0.12);
	}

	.featured-deck-rule {
		width: 80px;
		height: 3px;
		background: #ff00ff;
		margin: 0 auto 24px;
		opacity: 0.7;
	}

	.featured-deck {
		font-family: 'Inter', sans-serif;
		font-size: clamp(1rem, 2vw, 1.2rem);
		color: rgba(255,255,255,0.7);
		line-height: 1.7;
		margin-bottom: 30px;
		font-style: italic;
	}

	.featured-body-columns {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 30px;
		text-align: left;
		margin-bottom: 36px;
		border-top: 1px solid rgba(255,0,255,0.15);
		border-bottom: 1px solid rgba(255,0,255,0.15);
		padding: 24px 0;
	}

	.featured-body-columns p {
		font-family: 'Inter', sans-serif;
		font-size: 0.9rem;
		color: rgba(255,255,255,0.5);
		line-height: 1.8;
	}

	.featured-read-more {
		display: inline-block;
		font-family: 'Oswald', 'Bebas Neue', sans-serif;
		font-size: 1rem;
		letter-spacing: 3px;
		text-transform: uppercase;
		color: #ffffff;
		background: #ff00ff;
		padding: 14px 40px;
		border: none;
		transition: all 0.3s ease;
		box-shadow: 0 4px 20px rgba(255,0,255,0.35);
	}

	.featured-read-more:hover {
		transform: translateY(-3px);
		box-shadow: 0 8px 30px rgba(255,0,255,0.5);
		color: #ffffff;
		text-shadow: none;
	}

	/* ── GRUNGE DIVIDERS ── */
	.grunge-divider {
		display: block;
		line-height: 0;
		margin: 0;
	}

	.grunge-divider svg {
		display: block;
		width: 100%;
		height: 40px;
	}

	/* ── CHRONICLES SECTION ── */
	.chronicles-section {
		background: var(--charcoal);
		position: relative;
	}

	.chronicles-section::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image:
			url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.68' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.05'/%3E%3C/svg%3E");
		background-size: 256px 256px;
		pointer-events: none;
		opacity: 0.6;
	}

	.section-header {
		display: flex;
		align-items: center;
		gap: 24px;
		margin-bottom: 60px;
	}

	.section-rule {
		flex: 1;
		height: 2px;
		background: linear-gradient(90deg, transparent, rgba(255,0,255,0.4) 60%);
	}

	.section-rule:last-child {
		background: linear-gradient(270deg, transparent, rgba(255,0,255,0.4) 60%);
	}

	.section-title {
		font-family: 'Bebas Neue', sans-serif;
		font-size: clamp(2rem, 4vw, 3.2rem);
		color: #ffffff;
		white-space: nowrap;
		letter-spacing: 2px;
		text-shadow: 1px 2px 6px rgba(0,0,0,0.6);
	}

	.stories-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 30px;
		position: relative;
	}

	.story-card {
		background: var(--bg-card);
		border: 1px solid rgba(255,0,255,0.15);
		overflow: hidden;
		transition: all 0.3s ease;
		position: relative;
	}

	.story-card::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image:
			url("data:image/svg+xml,%3Csvg viewBox='0 0 300 300' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
		background-size: 200px 200px;
		pointer-events: none;
		z-index: 0;
		opacity: 0.8;
	}

	.story-card:hover {
		transform: translateY(-6px);
		border-color: rgba(255,0,255,0.4);
		box-shadow:
			0 12px 40px rgba(0,0,0,0.6),
			0 0 20px rgba(255,0,255,0.08);
	}

	/* ── BRANDED THUMBNAILS ── */
	.story-card-thumb {
		aspect-ratio: 16/9;
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		gap: 12px;
	}

	.thumb-texture {
		position: absolute;
		inset: 0;
		background-image:
			url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.12'/%3E%3C/svg%3E");
		background-size: 128px 128px;
		mix-blend-mode: overlay;
		pointer-events: none;
	}

	.thumb-icon {
		width: 52px;
		height: 52px;
		position: relative;
		z-index: 1;
		opacity: 0.85;
	}

	.thumb-label {
		font-family: 'Oswald', 'Bebas Neue', sans-serif;
		font-size: 0.7rem;
		letter-spacing: 3px;
		text-transform: uppercase;
		position: relative;
		z-index: 1;
		opacity: 0.7;
	}

	.story-thumb-action {
		background: linear-gradient(135deg, #1f2030 0%, #181b22 60%, #1a1d2a 100%);
		color: #ff00ff;
	}

	.story-thumb-profile {
		background: linear-gradient(135deg, #1a1d2e 0%, #181b22 60%, #1f2230 100%);
		color: #ff00ff;
	}

	.story-thumb-bts {
		background: linear-gradient(135deg, #1e2030 0%, #181b22 60%, #1a1d2a 100%);
		color: #ff00ff;
	}

	.story-thumb-guide {
		background: linear-gradient(135deg, #1f2030 0%, #181b22 60%, #1a1c28 100%);
		color: #ff00ff;
	}

	.story-thumb-legends {
		background: linear-gradient(135deg, #20152e 0%, #181b22 60%, #1c1430 100%);
		color: #ff00ff;
	}

	.story-thumb-review {
		background: linear-gradient(135deg, #141e2e 0%, #181b22 60%, #121a28 100%);
		color: #ff00ff;
	}

	.story-card:hover .thumb-icon {
		opacity: 1;
		transform: scale(1.08);
		transition: all 0.3s ease;
	}

	/* ── CARD CONTENT ── */
	.story-card-content {
		padding: 22px 24px 26px;
		position: relative;
		z-index: 1;
	}

	.story-category {
		display: inline-block;
		font-family: 'Oswald', 'Bebas Neue', sans-serif;
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 2.5px;
		text-transform: uppercase;
		padding: 3px 10px;
		margin-bottom: 12px;
		border-width: 1px;
		border-style: solid;
	}

	.cat-action    { color: #ff00ff; border-color: #ff00ff; background: rgba(255,0,255,0.08); }
	.cat-profile   { color: #ff00ff; border-color: #ff00ff; background: rgba(255,0,255,0.08); }
	.cat-bts       { color: #ff00ff; border-color: #ff00ff; background: rgba(255,0,255,0.08); }
